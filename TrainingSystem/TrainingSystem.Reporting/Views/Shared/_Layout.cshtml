@using Microsoft.AspNetCore.Http

@{
    var token = Context.Session.GetString("token");
    var isLoggedIn = !string.IsNullOrEmpty(token);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrainingSystem.Reporting</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrainingSystem.Reporting.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }

        .page-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }

        .custom-navbar {
            background-color: #ffffff;
            border-bottom: 1px solid #e9ecef;
            padding: 8px 0;
        }

        .navbar-brand {
            color: #0a1f5c !important;
            font-weight: 800;
            font-size: 1.35rem;
            text-decoration: none !important;
        }

        .nav-link {
            color: #0a1f5c !important;
            font-weight: 600;
            border-radius: 10px;
            padding: 8px 16px !important;
            text-decoration: none !important;
            transition: 0.2s ease;
        }

        .nav-link:hover,
        .nav-link:focus {
            background-color: rgba(10,31,92,0.08);
            color: #0a1f5c !important;
            text-decoration: none !important;
        }

        .login-btn {
            background-color: #0a1f5c;
            color: white !important;
            border-radius: 10px;
            padding: 8px 20px !important;
            font-weight: 700;
        }

        .login-btn:hover {
            background-color: #0a1f5c;
            color: white !important;
            opacity: 0.92;
        }

        .logout-btn {
            background-color: #dc3545;
            color: white !important;
            border-radius: 10px;
            padding: 8px 20px !important;
            font-weight: 700;
        }

        .logout-btn:hover {
            background-color: #c82333;
            color: white !important;
        }

        footer {
            background-color: #ffffff;
            border-top: 1px solid #e9ecef;
            color: #0a1f5c;
            padding: 14px 0;
            margin-top: auto;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="page-wrapper">

        <header>
            <nav class="navbar navbar-expand-sm custom-navbar">
                <div class="container-fluid px-4">

                    <a class="navbar-brand" href="/">
                        Training System Reporting
                    </a>

                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarNav"
                            aria-controls="navbarNav"
                            aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarNav">

                        <ul class="navbar-nav ms-auto align-items-sm-center gap-2">

                            <li class="nav-item">
                                <a class="nav-link" href="/">Home</a>
                            </li>

                            @if (isLoggedIn)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Reports">Reports</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link logout-btn" href="/Auth/Logout">Logout</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link login-btn" href="/Auth/Login">Login</a>
                                </li>
                            }

                        </ul>

                    </div>
                </div>
            </nav>
        </header>

        <main role="main">
            <div class="container-fluid px-3 px-md-5">
                @RenderBody()
            </div>
        </main>

        <footer>
            <div class="container">
                &copy; 2026 - TrainingSystem.Reporting
            </div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>