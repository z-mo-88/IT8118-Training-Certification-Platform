@model IEnumerable<TrainingSystem.API.Models.InstructorExpertise>

@{
    ViewData["Title"] = "My Expertise";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Expertise</h2>
    <a asp-action="Create" class="btn btn-primary">Add Expertise</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Expertise</th>
                    <th style="width: 160px;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Expertise?.ExpertiseName</td>
                            <td class="text-center">
                                <a asp-action="Delete"
                                   asp-route-id="@item.InstructorExpertiseId"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted">No expertise added yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>