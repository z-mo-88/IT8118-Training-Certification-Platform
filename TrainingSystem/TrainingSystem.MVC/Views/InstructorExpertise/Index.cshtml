@model IEnumerable<TrainingSystem.API.Models.InstructorExpertise>

@{
    var roleId = Context.Session.GetInt32("RoleId");
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#0a1f5c;">Expertise</h2>
            <p class="text-muted mb-0">Manage instructor expertise areas.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create"
               asp-route-userId="@targetUserId"
               class="btn text-white fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
               style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px; line-height:1;">
                Add Expertise
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:18px; overflow:hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color:rgba(10,31,92,0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color:#0a1f5c;">Expertise</th>
                            @if (roleId == 3)
                            {
                                <th class="fw-semibold py-3 text-center" style="color:#0a1f5c;">Actions</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">
                                        @item.Expertise?.ExpertiseName
                                    </td>

                                    @if (roleId == 3)
                                    {
                                        <td class="text-center py-3">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a asp-action="Edit"
                                                   asp-route-id="@item.InstructorExpertiseId"
                                                   asp-route-userId="@targetUserId"
                                                   class="btn btn-sm fw-semibold px-3 d-inline-flex align-items-center justify-content-center"
                                                   style="background-color:#ffc107; border-radius:10px; border:none; color:#212529; line-height:1;">
                                                    Edit
                                                </a>

                                                <a asp-action="Delete"
                                                   asp-route-id="@item.InstructorExpertiseId"
                                                   asp-route-userId="@targetUserId"
                                                   class="btn btn-sm text-white fw-semibold px-3 d-inline-flex align-items-center justify-content-center"
                                                   style="background-color:#dc3545; border-radius:10px; border:none; line-height:1;">
                                                    Delete
                                                </a>
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted py-5">
                                    No expertise added yet.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>

</div>