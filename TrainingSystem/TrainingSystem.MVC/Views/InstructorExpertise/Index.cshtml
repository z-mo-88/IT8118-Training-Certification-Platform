@model IEnumerable<TrainingSystem.API.Models.InstructorExpertise>

@{
    var roleId = Context.Session.GetInt32("RoleId");
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1" style="color:#0a1f5c;">Expertise</h3>
            <p class="text-muted mb-0">Your areas of specialization</p>
        </div>

        <a asp-action="Create"
           asp-route-userId="@targetUserId"
           class="btn text-white px-4"
           style="background:#0a1f5c; border-radius:10px;">
            + Add Expertise
        </a>

    </div>

    <!-- LIST -->
    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">

            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 p-3"
                         style="border:1px solid #e9ecef; border-radius:12px;">

                        <!-- NAME -->
                        <div class="fw-semibold" style="color:#0a1f5c;">
                            @item.Expertise?.ExpertiseName
                        </div>

                        <!-- ACTIONS -->
                        @if (roleId == 3)
                        {
                            <div class="d-flex gap-2">

                                <a asp-action="Edit"
                                   asp-route-id="@item.InstructorExpertiseId"
                                   asp-route-userId="@targetUserId"
                                   class="btn btn-sm"
                                   style="background:#ffc107; border-radius:8px;">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.InstructorExpertiseId"
                                   asp-route-userId="@targetUserId"
                                   class="btn btn-sm text-white"
                                   style="background:#dc3545; border-radius:8px;">
                                    Delete
                                </a>

                            </div>
                        }

                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-4">
                    No expertise added yet.
                </div>
            }

        </div>
    </div>

</div>