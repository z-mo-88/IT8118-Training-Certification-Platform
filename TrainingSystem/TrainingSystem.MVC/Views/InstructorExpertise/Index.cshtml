@model IEnumerable<TrainingSystem.API.Models.InstructorExpertise>
@using System.Security.Claims

@{
    var roleId = int.Parse(User.FindFirst(ClaimTypes.Role)?.Value ?? "0");
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container py-5">

    <div class="d-flex justify-content-between mb-4">
        <h2>Expertise</h2>

        <!-- ADD -->
        <a asp-action="Create"
           asp-route-userId="@targetUserId"
           class="btn btn-primary">
            Add Expertise
        </a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Expertise</th>
                @if (roleId == 3)
                {
                    <th class="text-center">Actions</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Expertise?.ExpertiseName</td>

                    <td class="text-center">

                        @if (roleId == 3)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.InstructorExpertiseId"
                               asp-route-userId="@targetUserId"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.InstructorExpertiseId"
                               asp-route-userId="@targetUserId"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>
                        }

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>