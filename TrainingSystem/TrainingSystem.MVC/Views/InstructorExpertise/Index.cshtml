@model IEnumerable<TrainingSystem.API.Models.InstructorExpertise>
@using Microsoft.AspNetCore.Http

@{
    var targetUserId = ViewBag.TargetUserId;
    var roleId = Context.Session.GetInt32("RoleId");

    ViewData["Title"] = roleId == 3 ? "Edit Expertise" : "My Expertise";

    var pageTitle = roleId == 3 ? "Edit Expertise" : "My Expertise";
    var pageSubtitle = roleId == 3
        ? "Manage the available expertise for the instructor."
        : "Manage your areas of expertise.";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">@pageTitle</h2>
            <p class="text-muted mb-0">@pageSubtitle</p>
        </div>

        <a asp-action="Create"
           asp-route-userId="@targetUserId"
           class="btn text-white fw-semibold px-4"
           style="background-color: #0a1f5c; border-radius: 10px; border: none;">
            Add Expertise
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 18px;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="px-4 py-3">Expertise</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3">
                                        <span class="badge bg-light text-dark px-3 py-2">
                                            @item.Expertise?.ExpertiseName
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <a asp-action="Delete"
                                           asp-route-id="@item.InstructorExpertiseId"
                                           asp-route-userId="@targetUserId"
                                           class="btn btn-sm fw-semibold text-white px-3"
                                           style="background-color: #dc3545; border-radius: 10px; border: none;">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="text-center text-muted py-5">
                                    No expertise records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>