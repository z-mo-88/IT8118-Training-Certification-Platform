@model TrainingSystem.API.Models.InstructorExpertise

@{
    ViewData["Title"] = "Delete Expertise";
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">

            <div class="card border-0 shadow-sm text-center" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold text-danger mb-3">Delete Expertise</h3>
                    <p class="text-muted mb-4">Are you sure you want to delete this expertise?</p>

                    <div class="mb-4 text-start mx-auto" style="max-width:420px;">
                        <div class="d-flex justify-content-between py-2">
                            <span class="fw-semibold" style="color:#0a1f5c;">Expertise</span>
                            <span class="text-muted">@Model.Expertise?.ExpertiseName</span>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="InstructorExpertiseId" type="hidden" />
                        <input type="hidden" name="userId" value="@targetUserId" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index"
                               asp-route-userId="@targetUserId"
                               class="btn fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px; line-height:1;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                                    style="background-color:#dc3545; border-radius:10px; border:none; height:46px; line-height:1;">
                                Delete
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>