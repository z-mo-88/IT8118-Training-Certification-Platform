@model TrainingSystem.API.Models.InstructorExpertise
@using Microsoft.AspNetCore.Http

@{
    var roleId = Context.Session.GetInt32("RoleId");

    ViewData["Title"] = "Add Expertise";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Add Expertise</h3>
                    <p class="text-muted mb-4">Add a new expertise area.</p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label class="fw-semibold mb-2" style="color:#0a1f5c;">Expertise</label>
                            <select asp-for="ExpertiseId"
                                    asp-items="ViewBag.ExpertiseList"
                                    class="form-select"
                                    style="height:50px; border-radius:10px;">
                                <option value="">-- Select Expertise --</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                               asp-route-userId="@Model.UserId"
                               class="btn"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white"
                                    style="background:#0a1f5c; border-radius:10px;">
                                Save
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>