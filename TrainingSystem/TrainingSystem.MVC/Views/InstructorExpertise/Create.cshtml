@model TrainingSystem.API.Models.InstructorExpertise
@using Microsoft.AspNetCore.Http

@{
    var roleId = Context.Session.GetInt32("RoleId");

    ViewData["Title"] = "Add Expertise";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Add Expertise</h3>
                        <p class="text-muted mb-0">Add a new expertise area.</p>
                    </div>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="color:#0a1f5c;">Expertise</label>
                            <select asp-for="ExpertiseId"
                                    asp-items="ViewBag.ExpertiseList"
                                    class="form-select"
                                    style="height:50px; border-radius:10px;">
                                <option value="">-- Select Expertise --</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               asp-route-userId="@Model.UserId"
                               class="btn fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px; line-height:1;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                                    style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px; line-height:1;">
                                Save
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>