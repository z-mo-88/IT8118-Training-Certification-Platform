@model TrainingSystem.API.Models.InstructorExpertise

@{
    ViewData["Title"] = "Add Expertise";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">

                <div class="card-body p-4 p-lg-5">
                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Add Expertise</h3>
                        <p class="text-muted mb-0">Select an expertise area to add to your profile.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All"
                             class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="ExpertiseId"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Expertise Area</label>

                            <select asp-for="ExpertiseId"
                                    asp-items="ViewBag.Expertise"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                                <option value="">Select Expertise</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Save
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}