@model TrainingSystem.API.Models.InstructorExpertise

@{
    var roleId = Context.Session.GetInt32("RoleId");
    var targetUserId = ViewBag.TargetUserId;
}

@if (roleId != 3)
{
    <div class="container py-5">
        <div class="alert alert-danger text-center">
            Access Denied
        </div>

        <a href="/Instructor" class="btn btn-secondary mt-3">
            Back to Instructors
        </a>
    </div>
}
else
{
    <div class="container py-5">

      
        <a href="/Instructor" class="btn btn-outline-secondary mb-3">
             Back to Instructors
        </a>

        <div class="card border-0 shadow-sm mx-auto" style="max-width: 700px; border-radius: 18px;">
            <div class="card-body p-4 p-md-5">

                <h2 class="fw-bold mb-4 text-center" style="color:#0a1f5c;">
                    Edit Expertise
                </h2>

                <form asp-action="Edit" method="post">

                 
                    <input type="hidden" asp-for="InstructorExpertiseId" />
                    <input type="hidden" name="userId" value="@targetUserId" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="color:#0a1f5c;">
                            Expertise
                        </label>

                        <select asp-for="ExpertiseId"
                                asp-items="ViewBag.ExpertiseList"
                                class="form-select"
                                style="height:50px; border-radius:10px;">
                        </select>
                    </div>

                    <div class="d-flex justify-content-between mt-4">

                        <a asp-action="Index"
                           asp-route-userId="@targetUserId"
                           class="btn btn-outline-secondary px-4"
                           style="border-radius:10px;">
                            Cancel
                        </a>

                        <button type="submit"
                                class="btn text-white px-4"
                                style="background:#0a1f5c; border-radius:10px;">
                            Save Changes
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
}