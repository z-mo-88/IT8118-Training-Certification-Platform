@model TrainingSystem.API.Models.Payment

@{
    ViewData["Title"] = "Record Payment";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-6">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-md-5">

                    <h2 class="fw-bold mb-2" style="color: #0a1f5c;">Record Payment</h2>
                    <p class="text-muted mb-4">Enter payment details for an enrollment.</p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="EnrollmentId" class="form-label fw-semibold" style="color: #0a1f5c;">Enrollment</label>
                            <select asp-for="EnrollmentId"
                                    asp-items="ViewBag.Enrollments"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                                <option value="">Select Enrollment</option>
                            </select>
                            <span asp-validation-for="EnrollmentId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="AmountPaid" class="form-label fw-semibold" style="color: #0a1f5c;">Amount Paid</label>
                            <input asp-for="AmountPaid"
                                   class="form-control"
                                   placeholder="Enter amount paid"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="AmountPaid" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn px-4 d-flex align-items-center justify-content-center"
                               style="background-color: #f1f3f5; border-radius: 10px; height: 46px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-flex align-items-center justify-content-center"
                                    style="background-color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                                Save
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}