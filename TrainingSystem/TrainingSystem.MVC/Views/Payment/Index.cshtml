@model IEnumerable<TrainingSystem.API.Models.Payment>

@{
    ViewData["Title"] = "Payments";

    var groupedPayments = Model?
        .Where(p => p.Enrollment?.User != null)
        .GroupBy(p => new
        {
            UserId = p.Enrollment!.User!.UserId,
            Name = p.Enrollment.User.Name,
            Email = p.Enrollment.User.Email
        })
        .OrderBy(g => g.Key.UserId)
        .ToList();
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Payments</h2>
            <p class="text-muted mb-0">View payment history grouped by trainee and track remaining balances clearly.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create"
               class="btn text-white fw-semibold px-4"
               style="background-color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                Record Payment
            </a>
        </div>
    </div>

    @if (groupedPayments != null && groupedPayments.Any())
    {
        @foreach (var userGroup in groupedPayments)
        {
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px; overflow: hidden;">
                <div class="card-header border-0 py-3 px-4" style="background-color: rgba(10, 31, 92, 0.06);">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-2">
                            <span class="fw-semibold" style="color: #0a1f5c;">User ID:</span>
                            <span class="text-muted">@userGroup.Key.UserId</span>
                        </div>
                        <div class="col-md-4">
                            <span class="fw-semibold" style="color: #0a1f5c;">Student:</span>
                            <span class="text-muted">@userGroup.Key.Name</span>
                        </div>
                        <div class="col-md-6">
                            <span class="fw-semibold" style="color: #0a1f5c;">Email:</span>
                            <span class="text-muted">@userGroup.Key.Email</span>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Course</th>
                                    <th class="fw-semibold py-3" style="color: #0a1f5c;">Amount Paid</th>
                                    <th class="fw-semibold py-3" style="color: #0a1f5c;">Remaining Balance</th>
                                    <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                                    <th class="fw-semibold py-3" style="color: #0a1f5c;">Date</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in userGroup.OrderByDescending(p => p.PaidDate))
                                {
                                    var remainingBalance = item.Enrollment?.OutstandingBalance ?? 0m;
                                    var displayStatus = remainingBalance <= 0 ? "Paid" : "Partial";

                                    <tr>
                                        <td class="px-4 py-3 text-muted">
                                            @item.Enrollment?.Session?.Course?.Title
                                        </td>

                                        <td class="py-3 fw-semibold" style="color: #0a1f5c;">
                                            @item.AmountPaid
                                        </td>

                                        <td class="py-3 fw-semibold"
                                            style="color:@(remainingBalance > 0 ? "#dc3545" : "#198754")">
                                            @remainingBalance
                                        </td>

                                        <td class="py-3">
                                            <span class="badge rounded-pill px-3 py-2 @(displayStatus == "Paid" ? "bg-success" : "bg-warning text-dark")">
                                                @displayStatus
                                            </span>
                                        </td>

                                        <td class="py-3 text-muted">
                                            @item.PaidDate
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius: 18px;">
            <div class="card-body text-center text-muted py-5">
                No payments found.
            </div>
        </div>
    }

</div>