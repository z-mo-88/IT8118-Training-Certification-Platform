@model IEnumerable<TrainingSystem.API.Models.SubjectCategory>

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4 d-flex justify-content-between">
        <div>
            <h2 class="fw-bold" style="color:#0a1f5c;">Categories</h2>
            <p class="text-muted">Manage course categories.</p>
        </div>

        <a asp-action="Create"
           class="btn text-white fw-semibold px-4"
           style="background:#0a1f5c; border-radius:10px;">
            Add Category
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="table-responsive">
            <table class="table align-middle mb-0">

                <thead style="background:rgba(10,31,92,0.06);">
                    <tr>
                        <th class="px-4 py-3">Name</th>
                        <th>Description</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="px-4 fw-semibold">@c.CategoryName</td>
                            <td class="text-muted">@c.Description</td>

                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@c.CategoryId"
                                   class="btn btn-sm btn-warning px-3">Edit</a>

                                <a asp-action="Delete" asp-route-id="@c.CategoryId"
                                   class="btn btn-sm btn-danger px-3">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

</div>