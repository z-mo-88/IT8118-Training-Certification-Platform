@model IEnumerable<TrainingSystem.API.Models.SubjectCategory>

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1" style="color:#0a1f5c;">Categories</h2>
            <p class="text-muted mb-0">Manage course categories.</p>
        </div>

        <a asp-action="Create"
           class="btn text-white"
           style="background-color:#0a1f5c; border-radius:10px; font-weight:600;">
            + Add Category
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">

            @foreach (var c in Model)
            {
                <div class="d-flex justify-content-between align-items-center mb-3 p-3"
                     style="border:1px solid #e9ecef; border-radius:12px;">

                    <div>
                        <div class="fw-semibold" style="color:#0a1f5c;">
                            @c.CategoryName
                        </div>
                        <div class="text-muted small">
                            @c.Description
                        </div>
                    </div>

                    <div class="d-flex gap-2">

                        <a asp-action="Edit"
                           asp-route-id="@c.CategoryId"
                           class="btn btn-sm"
                           style="background:#ffc107; border-radius:8px;">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@c.CategoryId"
                           class="btn btn-sm text-white"
                           style="background:#dc3545; border-radius:8px;">
                            Delete
                        </a>

                    </div>

                </div>
            }

        </div>
    </div>

</div>