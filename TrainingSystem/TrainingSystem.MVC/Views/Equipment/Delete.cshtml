@model TrainingSystem.API.Models.Equipment

@{
    ViewData["Title"] = "Delete Equipment";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2 text-danger">Delete Equipment</h3>
                        <p class="text-muted mb-0">
                            Are you sure you want to delete this equipment?
                        </p>
                    </div>

                    <div class="mb-4 p-3 rounded-3" style="background-color: #f8f9fc;">
                        <div class="mb-2">
                            <span class="fw-semibold" style="color: #0a1f5c;">Equipment Name:</span>
                            <span class="text-muted">@Model.EquipmentName</span>
                        </div>

                        <div>
                            <span class="fw-semibold" style="color: #0a1f5c;">Description:</span>
                            <span class="text-muted">@Model.Description</span>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="EquipmentId" type="hidden" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #dc3545; height: 48px; border-radius: 10px; border: none;">
                                Delete
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>