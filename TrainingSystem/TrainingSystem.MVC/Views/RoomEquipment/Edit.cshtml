@model TrainingSystem.API.Models.RoomEquipment

@{
    ViewData["Title"] = "Edit Room Equipment";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="mb-4">Edit Room Equipment</h2>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="RoomEquipmentId" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="RoomId" class="form-label">Room</label>
                        <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EquipmentId" class="form-label">Equipment</label>
                        <select asp-for="EquipmentId" asp-items="ViewBag.Equipments" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Save Changes</button>
                        <a asp-action="Index" class="btn btn-secondary">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}