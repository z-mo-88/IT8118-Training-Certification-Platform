@model TrainingSystem.API.Models.RoomEquipment

@{
    ViewData["Title"] = "Add Room Equipment";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Add Room Equipment</h3>
                        <p class="text-muted mb-0">Assign equipment to a room.</p>
                    </div>

                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Room
                            </label>
                            <select asp-for="RoomId"
                                    asp-items="ViewBag.Rooms"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Equipment
                            </label>
                            <select asp-for="EquipmentId"
                                    asp-items="ViewBag.Equipments"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Quantity
                            </label>
                            <input asp-for="Quantity"
                                   class="form-control"
                                   placeholder="Enter quantity"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Save
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>