@model IEnumerable<TrainingSystem.API.Models.RoomEquipment>

@{
    ViewData["Title"] = "Room Equipment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Room Equipment</h2>
    <a asp-action="Create" class="btn btn-primary">Add</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Room</th>
                    <th>Equipment</th>
                    <th>Quantity</th>
                    <th style="width: 180px;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Room?.RoomName</td>
                            <td>@item.Equipment?.EquipmentName</td>
                            <td>@item.Quantity</td>
                            <td class="text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.RoomEquipmentId"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>
                                    <a asp-action="Delete"
                                       asp-route-id="@item.RoomEquipmentId"
                                       class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No data</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>