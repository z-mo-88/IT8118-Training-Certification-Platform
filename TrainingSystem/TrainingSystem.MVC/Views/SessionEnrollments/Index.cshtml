@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "Session Students";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">
            Session Students
        </h2>
        <p class="text-muted mb-0">
            Manage attendance and results for this session.
        </p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10,31,92,0.06);">
                        <tr>
                            <th class="px-4 py-3">Student Name</th>
                            <th>Status</th>
                            <th>Result</th>
                            <th>Remarks</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var e in Model)
                            {
                                var result = e.AssessmentResults?.FirstOrDefault();

                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">
                                        @e.User?.Name
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10,31,92,0.08); color:#0a1f5c;">
                                            @e.Status
                                        </span>
                                    </td>

                                    <td>
                                        @if (result != null)
                                        {
                                            if (result.IsPassed)
                                            {
                                                <span class="badge bg-success">Pass</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Fail</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not Recorded</span>
                                        }
                                    </td>

                                    <td class="text-muted">
                                        @(string.IsNullOrWhiteSpace(result?.Remarks) ? "-" : result!.Remarks)
                                    </td>

                                    <td class="text-center">

                                        @if (result != null)
                                        {
                                            <span class="text-success fw-semibold">
                                                Result Recorded
                                            </span>
                                        }
                                        else
                                        {
                                            <form asp-action="RecordResult"
                                                  method="post"
                                                  class="d-flex gap-2 justify-content-center">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="enrollmentId" value="@e.EnrollmentId" />

                                                <input type="text"
                                                       name="remarks"
                                                       placeholder="Remarks"
                                                       class="form-control form-control-sm"
                                                       style="width:120px;"
                                                       required />

                                                <button type="submit"
                                                        name="isPassed"
                                                        value="true"
                                                        class="btn btn-sm btn-success">
                                                    Pass
                                                </button>

                                                <button type="submit"
                                                        name="isPassed"
                                                        value="false"
                                                        class="btn btn-sm btn-danger">
                                                    Fail
                                                </button>

                                            </form>
                                        }

                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No students found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="InstructorSessions"
           asp-action="Index"
           class="btn btn-light fw-semibold">
            Back to My Sessions
        </a>
    </div>

</div>