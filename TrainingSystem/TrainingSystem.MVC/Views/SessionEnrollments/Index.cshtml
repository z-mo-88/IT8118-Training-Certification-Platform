@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "Session Enrollments";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Session Students</h2>
        <p class="text-muted mb-0">Manage attendance and results for this session.</p>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Student Name</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c;">Attendance</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Result</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                var result = item.AssessmentResults?.FirstOrDefault();

                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.User?.Name
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c;">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td class="text-center py-3">
                                        @if (item.Status != "Attending" && item.Status != "Completed")
                                        {
                                            <a asp-action="MarkAttending"
                                               asp-route-id="@item.EnrollmentId"
                                               class="btn btn-sm fw-semibold text-white px-3"
                                               style="background-color: #0a1f5c; border-radius: 10px; border: none;">
                                                Mark Attending
                                            </a>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Recorded
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td class="py-3">
                                        @if (item.Status == "Attending")
                                        {
                                            <form asp-action="RecordResult"
                                                  method="post"
                                                  class="d-flex flex-wrap gap-2 align-items-center">

                                                <input type="hidden"
                                                       name="enrollmentId"
                                                       value="@item.EnrollmentId" />

                                                <select name="isPassed"
                                                        class="form-select"
                                                        style="width:120px; border-radius: 10px;">
                                                    <option value="true">Pass</option>
                                                    <option value="false">Fail</option>
                                                </select>

                                                <input name="remarks"
                                                       placeholder="Remarks"
                                                       class="form-control"
                                                       style="width:150px; border-radius: 10px;" />

                                                <button type="submit"
                                                        class="btn btn-sm fw-semibold text-white px-3"
                                                        style="background-color: #198754; border-radius: 10px; border: none;">
                                                    Submit
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            if (result != null)
                                            {
                                                if (result.IsPassed)
                                                {
                                                    <span class="badge rounded-pill px-3 py-2"
                                                          style="background-color: #198754; color: white;">
                                                        Pass
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill px-3 py-2"
                                                          style="background-color: #dc3545; color: white;">
                                                        Fail
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    No students enrolled.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

    <div class="text-start">
        <a asp-controller="InstructorSessions"
           asp-action="Index"
           class="btn btn-light fw-semibold px-4"
           style="border-radius: 10px;">
            Back to My Sessions
        </a>
    </div>

</div>