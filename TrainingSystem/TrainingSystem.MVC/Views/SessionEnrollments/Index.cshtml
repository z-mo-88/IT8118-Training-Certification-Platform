@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "Session Enrollments";
}

<h1>Session Enrollments</h1>

<h4>Session ID: @ViewBag.SessionId</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Enrollment ID</th>
            <th>Trainee Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Enrollment Date</th>
            <th>Outstanding Balance</th>
            <th>Is Overdue</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var enrollment in Model)
        {
            <tr>
                <td>@enrollment.EnrollmentId</td>
                <td>@enrollment.User?.Name</td>
                <td>@enrollment.User?.Email</td>
                <td>@enrollment.Status</td>
                <td>@enrollment.EnrollmentDate</td>
                <td>@enrollment.OutstandingBalance</td>
                <td>@enrollment.IsOverdue</td>
            </tr>
        }
    </tbody>
</table>

