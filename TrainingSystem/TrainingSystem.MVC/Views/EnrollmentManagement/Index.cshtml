@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollment Management";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Enrollment Management</h2>
        <p class="text-muted mb-0">Manage trainee enrollments and lifecycle status.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Trainee</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Course</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Session Date</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Outstanding Balance</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Payment</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                var isPaid = item.OutstandingBalance <= 0;

                                string statusStyle = item.Status switch
                                {
                                    "Completed" => "background-color: #198754; color: white; font-weight: 600;",
                                    "Dropped" => "background-color: #dc3545; color: white; font-weight: 600;",
                                    "Confirmed" => "background-color: #0d6efd; color: white; font-weight: 600;",
                                    "Attending" => "background-color: #20c997; color: white; font-weight: 600;",
                                    _ => "background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;"
                                };

                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.User?.Name
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Session?.Course?.Title
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Session?.SessionDate.ToShortDateString()
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2" style="@statusStyle">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td class="py-3 fw-semibold"
                                        style="color:@(item.OutstandingBalance > 0 ? "#dc3545" : "#198754")">
                                        @item.OutstandingBalance
                                    </td>

                                    <td class="py-3">
                                        @if (isPaid)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Paid
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #ffc107; color: #212529;">
                                                Partial / Unpaid
                                            </span>
                                        }
                                    </td>

                                    <td class="py-3 text-center">
                                        @if (item.Status == "Enrolled" && isPaid)
                                        {
                                            <form asp-action="Confirm" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.EnrollmentId" />
                                                <button type="submit"
                                                        class="btn btn-sm fw-semibold text-white px-3"
                                                        style="background-color: #0d6efd; border-radius: 10px; border: none;">
                                                    Confirm
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status == "Confirmed")
                                        {
                                            <form asp-action="MarkAttending" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.EnrollmentId" />
                                                <button type="submit"
                                                        class="btn btn-sm fw-semibold text-white px-3"
                                                        style="background-color: #20c997; border-radius: 10px; border: none;">
                                                    Mark Attending
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    No enrollments found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>