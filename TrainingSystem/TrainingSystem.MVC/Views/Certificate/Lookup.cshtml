@{
    ViewData["Title"] = "Certificate Lookup";
}

<h2>Certificate Lookup</h2>

<form method="post">
    <div class="form-group">
        <label>Trainee ID</label>
        <input name="userId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Certificate Reference</label>
        <input name="reference" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

@if (ViewBag.ResultMessage != null)
{
    <p class="text-danger">@ViewBag.ResultMessage</p>
}

@if (ViewBag.CertificateId != null)
{
    <hr />
    <h4>Certificate Details</h4>

    <p><strong>Reference:</strong> @ViewBag.CertificateReferenceNumber</p>
    <p><strong>Status:</strong> @ViewBag.CertificateStatus</p>
    <p><strong>Issued Date:</strong> @ViewBag.IssuedDate</p>
    <p><strong>Track:</strong> @ViewBag.TrackName</p>
}