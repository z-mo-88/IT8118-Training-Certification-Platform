@{
    ViewData["Title"] = "Certificate Lookup";
}

<div class="container" style="max-width:500px;">
    <h2 class="text-center mb-3">Certificate Lookup</h2>

    <form method="post">
        <input name="userId" class="form-control mb-2" placeholder="User ID" required />
        <input name="reference" class="form-control mb-2" placeholder="Reference" required />
        <button class="btn btn-primary w-100">Search</button>
    </form>

    @if (ViewBag.CertificateId != null)
    {
        <div class="alert alert-success mt-3">
            Found: @ViewBag.TrackName
        </div>
    }

    @if (ViewBag.ResultMessage != null)
    {
        <div class="alert alert-danger mt-3">
            @ViewBag.ResultMessage
        </div>
    }
</div>