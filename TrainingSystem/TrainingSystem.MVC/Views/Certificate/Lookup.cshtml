@using System.Collections
@{
    ViewData["Title"] = "Certificate Lookup";

    var completedCourses = ViewBag.CompletedCourses as IEnumerable;
}

<div class="container-fluid py-5 px-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <!-- Search Card -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Certificate Lookup</h3>
                        <p class="text-muted mb-0">Search for a certificate using trainee ID and reference.</p>
                    </div>

                    <form method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                    Trainee ID
                                </label>
                                <input name="userId"
                                       type="number"
                                       min="1"
                                       required
                                       class="form-control"
                                       placeholder="Enter trainee ID"
                                       value="@(ViewBag.SearchedUserId ?? "")"
                                       style="height: 50px; border-radius: 10px;" />
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                    Certificate Reference
                                </label>
                                <input name="reference"
                                       required
                                       class="form-control"
                                       placeholder="Enter reference number"
                                       value="@(ViewBag.SearchedReference ?? "")"
                                       style="height: 50px; border-radius: 10px;" />
                            </div>
                        </div>

                        <div>
                            <button type="submit"
                                    class="btn text-white fw-semibold px-5"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Search
                            </button>
                        </div>
                    </form>

                    @if (ViewBag.ResultMessage != null)
                    {
                        <div class="alert alert-danger mt-4 rounded-3">
                            @ViewBag.ResultMessage
                        </div>
                    }
                </div>
            </div>

            @if (ViewBag.CertificateId != null)
            {
                <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                    <div class="card-body p-4 p-lg-5">

                        <h5 class="fw-bold mb-4" style="color: #0a1f5c;">
                            Certificate Details
                        </h5>

                        <div class="row">

                            <div class="col-md-3 mb-3">
                                <div class="fw-semibold" style="color: #0a1f5c;">Reference</div>
                                <div class="text-muted">@ViewBag.CertificateReferenceNumber</div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="fw-semibold" style="color: #0a1f5c;">Status</div>
                                <div>
                                    <span class="badge rounded-pill px-3 py-2"
                                          style="background-color: rgba(10,31,92,0.08); color: #0a1f5c;">
                                        @ViewBag.CertificateStatus
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="fw-semibold" style="color: #0a1f5c;">Issued Date</div>
                                <div class="text-muted">@ViewBag.IssuedDate</div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="fw-semibold" style="color: #0a1f5c;">Track</div>
                                <div class="text-muted">@ViewBag.TrackName</div>
                            </div>

                        </div>

                        <hr class="my-4" />

                        <h5 class="fw-bold mb-3" style="color: #0a1f5c;">
                            Completed Courses
                        </h5>

                        @if (completedCourses != null)
                        {
                            <div class="row">
                                @{
                                    bool hasCourses = false;
                                }

                                @foreach (var course in completedCourses)
                                {
                                    hasCourses = true;

                                    <div class="col-md-6 col-lg-4 mb-3">
                                        <div class="border rounded-3 p-3 h-100" style="background-color: #f8f9fc;">
                                            <div class="fw-semibold" style="color: #0a1f5c;">
                                                @course.GetType().GetProperty("Title")?.GetValue(course, null)
                                            </div>

                                            @if (course.GetType().GetProperty("IsRequired") != null)
                                            {
                                                var isRequired = course.GetType().GetProperty("IsRequired")?.GetValue(course, null);

                                                <div class="mt-2">
                                                    <span class="badge rounded-pill px-3 py-2"
                                                          style="background-color: rgba(10,31,92,0.08); color: #0a1f5c;">
                                                        @(isRequired != null && (bool)isRequired ? "Required" : "Optional")
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (!hasCourses)
                                {
                                    <div class="col-12">
                                        <div class="text-muted">
                                            No completed courses found.
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                No completed courses found.
                            </div>
                        }

                    </div>
                </div>
            }

        </div>
    </div>
</div>