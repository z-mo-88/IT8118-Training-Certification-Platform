@model TrainingSystem.API.Models.Certificate

@{
    ViewData["Title"] = "Issue Certificate";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Issue Certificate</h3>
                        <p class="text-muted mb-0">Assign a certificate to a trainee.</p>
                    </div>

                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Trainee
                            </label>
                            <select asp-for="UserId"
                                    asp-items="ViewBag.Users"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Track
                            </label>
                            <select asp-for="CertificationTrackId"
                                    asp-items="ViewBag.Tracks"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="color: #0a1f5c;">
                                Reference Number
                            </label>
                            <input asp-for="CertificateReferenceNumber"
                                   class="form-control"
                                   placeholder="Enter reference number"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <div class="d-grid">
                            <button type="submit"
                                    class="btn text-white fw-semibold"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Issue
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>