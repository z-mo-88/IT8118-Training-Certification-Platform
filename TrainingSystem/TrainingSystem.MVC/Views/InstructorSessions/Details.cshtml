@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Session Details";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-6">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Session Details</h3>
                        <p class="text-muted mb-0">View detailed information about this session.</p>
                    </div>

                    <div class="mb-4">
                        <h4 class="fw-semibold mb-3 text-center" style="color: #0a1f5c;">
                            @Model.Course?.Title
                        </h4>

                        <div class="d-flex flex-column gap-3">

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Room</span>
                                <span class="text-muted">@Model.Room?.RoomName</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Date</span>
                                <span class="text-muted">@Model.SessionDate.ToShortDateString()</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Time</span>
                                <span class="text-muted">@Model.StartTime - @Model.EndTime</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Status</span>
                                <span class="badge rounded-pill px-3 py-2"
                                      style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c;">
                                    @Model.Status
                                </span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Capacity</span>
                                <span class="text-muted">@Model.SessionCapacity</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Available Seats</span>
                                <span class="fw-semibold" style="color: #0a1f5c;">
                                    @Model.AvailableSeats
                                </span>
                            </div>

                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a asp-action="Index"
                           class="btn btn-light fw-semibold px-4"
                           style="border-radius: 10px;">
                            Back
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>