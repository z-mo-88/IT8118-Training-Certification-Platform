@model IEnumerable<TrainingSystem.API.Models.CourseEquipmentRequirement>

@{
    ViewData["Title"] = "Course Equipment Requirements";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Course Equipment Requirements</h2>
            <p class="text-muted mb-0">Manage the equipment required for each course.</p>
        </div>

        <a asp-action="Create"
           class="btn text-white fw-semibold px-4"
           style="background-color: #0a1f5c; border-radius: 10px; border: none;">
            Add Requirement
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Course</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Equipment</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Quantity Required</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Course?.Title
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Equipment?.EquipmentName
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c;">
                                            @item.QuantityRequired
                                        </span>
                                    </td>

                                    <td class="py-3 text-center">
                                        <form asp-action="Delete" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.CourseEquipmentRequirementId" />
                                            <button type="submit"
                                                    class="btn btn-sm fw-semibold text-white px-3"
                                                    style="background-color: #dc3545; border-radius: 10px; border: none;"
                                                    onclick="return confirm('Are you sure you want to delete this requirement?');">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    No course equipment requirements found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>