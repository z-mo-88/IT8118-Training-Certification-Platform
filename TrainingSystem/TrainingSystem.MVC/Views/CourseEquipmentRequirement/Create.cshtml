@model TrainingSystem.API.Models.CourseEquipmentRequirement

@{
    ViewData["Title"] = "Add Course Equipment Requirement";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-md-5">

                    <h2 class="fw-bold mb-2" style="color: #0a1f5c;">Add Course Equipment Requirement</h2>
                    <p class="text-muted mb-4">Define what equipment a course requires.</p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CourseId" class="form-label fw-semibold" style="color: #0a1f5c;">Course</label>
                            <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select" style="height: 50px; border-radius: 10px;">
                                <option value="">-- Select Course --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EquipmentId" class="form-label fw-semibold" style="color: #0a1f5c;">Equipment</label>
                            <select asp-for="EquipmentId" asp-items="ViewBag.Equipment" class="form-select" style="height: 50px; border-radius: 10px;">
                                <option value="">-- Select Equipment --</option>
                            </select>
                            <span asp-validation-for="EquipmentId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="QuantityRequired" class="form-label fw-semibold" style="color: #0a1f5c;">Quantity Required</label>
                            <input asp-for="QuantityRequired"
                                   class="form-control"
                                   placeholder="Enter required quantity"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="QuantityRequired" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index"
                               class="btn px-4"
                               style="background-color: #f1f3f5; border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; border-radius: 10px; border: none;">
                                Save
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}