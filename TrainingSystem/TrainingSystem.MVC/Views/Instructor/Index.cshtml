@model IEnumerable<TrainingSystem.MVC.Models.InstructorDisplayViewModel>

@{
    ViewData["Title"] = "Instructors";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Instructors</h2>
        <p class="text-muted mb-0">
            View and manage instructor information, expertise, and availability.
        </p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">

                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="px-4 py-3">Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Expertise</th>
                            <th>Availability</th>
                            <th>Bio</th>
                            <th>Notes</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <!-- NAME -->
                                    <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">
                                        @item.Name
                                    </td>

                                    <!-- EMAIL -->
                                    <td class="text-muted">
                                        @item.Email
                                    </td>

                                    <!-- PHONE -->
                                    <td class="text-muted">
                                        @item.PhoneNumber
                                    </td>

                                    <!-- EXPERTISE -->
                                    <td>
                                        @if (item.ExpertiseNames.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var exp in item.ExpertiseNames)
                                                {
                                                    <span class="badge bg-light text-dark px-2 py-1">
                                                        @exp
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- AVAILABILITY -->
                                    <td>
                                        @if (item.AvailabilityText.Any())
                                        {
                                            <ul class="mb-0 ps-3 text-muted">
                                                @foreach (var a in item.AvailabilityText)
                                                {
                                                    <li>@a</li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <!-- BIO -->
                                    <td class="text-muted">
                                        @item.Bio
                                    </td>

                                    <!-- NOTES -->
                                    <td class="text-muted">
                                        @item.Notes
                                    </td>

                                    <!-- STATUS -->
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2">
                                                Inactive
                                            </span>
                                        }
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    No instructors found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>