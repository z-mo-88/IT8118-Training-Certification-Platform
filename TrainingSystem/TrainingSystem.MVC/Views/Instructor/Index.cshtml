@model IEnumerable<TrainingSystem.MVC.Models.InstructorDisplayViewModel>

@{
    ViewData["Title"] = "Instructors";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Instructors</h2>
        <p class="text-muted mb-0">View and manage instructor information, expertise, and availability.</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Name</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Email</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Phone Number</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Expertise</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Availability</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c; width: 140px;">Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Name
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Email
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.PhoneNumber
                                    </td>

                                    <td class="py-3">
                                        @if (item.ExpertiseNames.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var expertise in item.ExpertiseNames)
                                                {
                                                    <span class="badge rounded-pill px-3 py-2"
                                                          style="background-color: rgba(10,31,92,0.08); color: #0a1f5c;">
                                                        @expertise
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No expertise assigned</span>
                                        }
                                    </td>

                                    <td class="py-3">
                                        @if (item.AvailabilityText.Any())
                                        {
                                            <ul class="mb-0 ps-3 text-muted">
                                                @foreach (var availability in item.AvailabilityText)
                                                {
                                                    <li>@availability</li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No availability added</span>
                                        }
                                    </td>

                                    <td class="text-center py-3">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #6c757d; color: white;">
                                                Inactive
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    No instructors found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>