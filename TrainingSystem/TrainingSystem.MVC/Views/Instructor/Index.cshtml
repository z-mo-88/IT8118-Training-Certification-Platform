@model IEnumerable<TrainingSystem.API.Models.User>

@{
    ViewData["Title"] = "Instructors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Instructors</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th style="width: 140px;" class="text-center">Active</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success px-3 py-2">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2">No</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No instructors found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>