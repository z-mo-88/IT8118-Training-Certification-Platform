@model TrainingSystem.API.Models.InstructorProfile

@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">

            <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">

                <div class="p-4 p-lg-5 text-white" style="background: linear-gradient(135deg, #0a1f5c, #163d8f);">
                    <h3 class="fw-bold mb-2">My Profile</h3>
                    <p class="mb-0" style="color: #dbe4ff;">
                        View and update your profile information.
                    </p>
                </div>

                <div class="card-body p-4 p-lg-5">

                    @if (TempData["Success"] != null)
                    {
                        <div id="successAlert" class="alert alert-success rounded-3 mb-4">
                            @TempData["Success"]
                        </div>
                    }

                    <form asp-action="Profile" method="post" id="profileForm">

                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-4 pb-4 border-bottom">
                            <h5 class="fw-bold mb-3" style="color:#0a1f5c;">Basic Information</h5>

                            <div class="row">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <div class="small text-muted mb-1">Instructor Name</div>
                                    <div class="fw-semibold" style="color:#0a1f5c;">
                                        @ViewBag.Name
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="small text-muted mb-1">Email</div>
                                    <div class="fw-semibold" style="color:#0a1f5c;">
                                        @ViewBag.Email
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4 pb-4 border-bottom">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="fw-bold mb-0" style="color:#0a1f5c;">Bio</h5>
                            </div>

                            <p id="bioText"
                               class="mb-0 text-muted"
                               style="line-height: 1.8; white-space: pre-line;">
                                @Model.Bio
                            </p>

                            <textarea id="bioInput"
                                      asp-for="Bio"
                                      class="form-control d-none"
                                      style="border-radius: 10px; min-height: 120px;"></textarea>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="fw-bold mb-0" style="color:#0a1f5c;">Notes</h5>
                            </div>

                            <p id="notesText"
                               class="mb-0 text-muted"
                               style="line-height: 1.8; white-space: pre-line;">
                                @Model.Notes
                            </p>

                            <textarea id="notesInput"
                                      asp-for="Notes"
                                      class="form-control d-none"
                                      style="border-radius: 10px; min-height: 120px;"></textarea>
                        </div>

                        <div class="d-flex gap-2 justify-content-end flex-wrap">

                            <button type="button"
                                    id="editBtn"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color:#0a1f5c; border-radius:10px; border:none;">
                                Edit
                            </button>

                            <button type="submit"
                                    id="saveBtn"
                                    class="btn text-white fw-semibold px-4 d-none"
                                    style="background-color:#0a1f5c; border-radius:10px; border:none;">
                                Save Changes
                            </button>

                            <button type="button"
                                    id="cancelBtn"
                                    class="btn btn-light fw-semibold px-4 d-none"
                                    style="border-radius:10px;">
                                Cancel
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const editBtn = document.getElementById("editBtn");
            const saveBtn = document.getElementById("saveBtn");
            const cancelBtn = document.getElementById("cancelBtn");

            const bioText = document.getElementById("bioText");
            const notesText = document.getElementById("notesText");

            const bioInput = document.getElementById("bioInput");
            const notesInput = document.getElementById("notesInput");

            let originalBio = bioInput.value;
            let originalNotes = notesInput.value;

            editBtn.addEventListener("click", function () {

                bioText.classList.add("d-none");
                notesText.classList.add("d-none");

                bioInput.classList.remove("d-none");
                notesInput.classList.remove("d-none");

                editBtn.classList.add("d-none");
                saveBtn.classList.remove("d-none");
                cancelBtn.classList.remove("d-none");
            });

            cancelBtn.addEventListener("click", function () {

                bioInput.value = originalBio;
                notesInput.value = originalNotes;

                bioText.classList.remove("d-none");
                notesText.classList.remove("d-none");

                bioInput.classList.add("d-none");
                notesInput.classList.add("d-none");

                editBtn.classList.remove("d-none");
                saveBtn.classList.add("d-none");
                cancelBtn.classList.add("d-none");
            });

            const alert = document.getElementById("successAlert");

            if (alert) {
                setTimeout(function () {
                    alert.style.transition = "opacity 0.5s";
                    alert.style.opacity = "0";

                    setTimeout(function () {
                        alert.remove();
                    }, 500);

                }, 1000);
            }

        });
    </script>
}