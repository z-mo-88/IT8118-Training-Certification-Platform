@model IEnumerable<TrainingSystem.API.Models.Course>

@{
    ViewData["Title"] = "Courses";
    var roleId = Context.Session.GetInt32("RoleId");
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Courses</h2>
            <p class="text-muted mb-0">Browse available courses and manage them.</p>
        </div>

        @if (roleId == 3)
        {
            <div class="mt-3 mt-md-0">
                <a asp-action="Create"
                   class="btn text-white fw-semibold px-4"
                   style="background-color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                    Create Course
                </a>
            </div>
        }
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 shadow-sm mb-4">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 shadow-sm mb-4">
            @TempData["Success"]
        </div>
    }

    @foreach (var course in Model)
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px; overflow: hidden;">
            <div class="card-body p-4">

                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start mb-3">
                    <div class="mb-3 mb-lg-0">
                        <h4 class="fw-bold mb-2" style="color: #0a1f5c;">
                            @course.Title
                        </h4>

                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge rounded-pill px-3 py-2"
                                  style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;">
                                Category: @course.Category?.CategoryName
                            </span>

                            <span class="badge rounded-pill px-3 py-2"
                                  style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;">
                                Duration: @course.DurationHours hrs
                            </span>

                            <span class="badge rounded-pill px-3 py-2"
                                  style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;">
                                Fee: @course.EnrollmentFee
                            </span>
                        </div>
                    </div>

                    @if (roleId == 3)
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit"
                               asp-route-id="@course.CourseId"
                               class="btn btn-sm fw-semibold text-white px-3"
                               style="background-color: #0a1f5c; border-radius: 10px; border: none;">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@course.CourseId"
                               class="btn btn-sm fw-semibold px-3"
                               style="background-color: #dc3545; color: white; border-radius: 10px; border: none;">
                                Delete
                            </a>
                        </div>
                    }
                </div>

                @if (roleId == 1)
                {
                    <div class="mt-4">
                        <h5 class="fw-semibold mb-3" style="color: #0a1f5c;">Available Sessions</h5>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead style="background-color: rgba(10, 31, 92, 0.06);">
                                    <tr>
                                        <th class="fw-semibold" style="color: #0a1f5c;">Date</th>
                                        <th class="fw-semibold" style="color: #0a1f5c;">Time</th>
                                        <th class="fw-semibold" style="color: #0a1f5c;">Seats</th>
                                        <th class="fw-semibold" style="color: #0a1f5c;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in course.CourseSessions)
                                    {
                                        <tr>
                                            <td>@session.SessionDate.ToShortDateString()</td>
                                            <td>@session.StartTime - @session.EndTime</td>

                                            <td>
                                                <span id="seats-@session.SessionId"
                                                      class="fw-semibold"
                                                      style="color: #0a1f5c;">
                                                    @session.AvailableSeats
                                                </span>
                                            </td>

                                            <td>
                                                <form asp-controller="Enrollments"
                                                      asp-action="Enroll"
                                                      method="post">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="sessionId"
                                                           value="@session.SessionId" />

                                                    <button class="btn btn-sm text-white fw-semibold px-3"
                                                            style="background-color: #198754; border-radius: 10px; border: none;"
                                                            @(session.AvailableSeats == 0 ? "disabled" : "")>
                                                        Enroll
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("https://localhost:5001/enrollmentHub")
            .build();

        connection.on("ReceiveSeatsUpdate", function (sessionId, seats) {
            const el = document.getElementById("seats-" + sessionId);
            if (el) el.innerText = seats;
        });

        connection.start()
            .then(() => console.log("SignalR connected"))
            .catch(err => console.error(err));
    </script>
}