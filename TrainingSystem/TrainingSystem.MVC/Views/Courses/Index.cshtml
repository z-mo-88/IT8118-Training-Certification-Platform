@model IEnumerable<TrainingSystem.API.Models.Course>

@{
    ViewData["Title"] = "Courses";

    var roleId = Context.Session.GetInt32("RoleId");
    var userId = Context.Session.GetInt32("UserId");

    var enrolledIds = ViewBag.EnrolledSessionIds as List<int>;
    var passedCourses = ViewBag.PassedCourseIds as List<int>;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Courses</h2>
            <p class="text-muted mb-0">Browse and manage courses.</p>
        </div>

        @if (roleId == 3)
        {
            <a asp-action="Create"
               class="btn btn-primary"
               style="border-radius:10px;">
                + Create Course
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- COURSES -->
    @foreach (var course in Model)
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px;">
            <div class="card-body p-4">

                <!-- COURSE HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-3">

                    <h4 class="fw-bold mb-0" style="color: #0a1f5c;">
                        @course.Title
                    </h4>

                    @if (roleId == 3)
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit"
                               asp-route-id="@course.CourseId"
                               class="btn btn-warning btn-sm">
                                Edit Course
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@course.CourseId"
                               class="btn btn-danger btn-sm">
                                Delete Course
                            </a>
                        </div>
                    }
                </div>

                <!-- COURSE INFO -->
                <div class="d-flex flex-wrap gap-2 mb-3">

                    <span class="badge bg-light text-dark px-3 py-2">
                        Category: @course.Category?.CategoryName
                    </span>

                    <span class="badge bg-light text-dark px-3 py-2">
                        Duration: @course.DurationHours hrs
                    </span>

                    <span class="badge bg-light text-dark px-3 py-2">
                        Fee: @course.EnrollmentFee
                    </span>

                    @if (course.PrerequisiteCourse != null)
                    {
                        <span class="badge bg-danger-subtle text-danger px-3 py-2">
                            Prerequisite: @course.PrerequisiteCourse.Title
                        </span>
                    }
                </div>

                <hr />

                <!-- SESSIONS -->
                <h5 class="fw-semibold mb-3" style="color: #0a1f5c;">
                    Sessions
                </h5>

                @if (course.CourseSessions != null && course.CourseSessions.Any())
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Seats</th>
                                <th>Instructor</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var session in course.CourseSessions)
                            {
                                var alreadyEnrolled = enrolledIds != null && enrolledIds.Contains(session.SessionId);

                                var sessionFull = session.AvailableSeats <= 0;

                                var prerequisiteMissing = course.PrerequisiteCourseId != null &&
                                (passedCourses == null || !passedCourses.Contains(course.PrerequisiteCourseId.Value));

                                <tr>
                                    <td>@session.SessionDate.ToShortDateString()</td>

                                    <td>
                                        @session.StartTime - @session.EndTime
                                    </td>

                                    <td id="seats-@session.SessionId">
                                        @session.AvailableSeats
                                    </td>

                                    <td>
                                        @session.User?.Name <br />
                                        <small class="text-muted">
                                            @session.User?.InstructorProfile?.Bio
                                        </small>
                                    </td>

                                    <td>
                                        @if (roleId == 1)
                                        {
                                            if (alreadyEnrolled)
                                            {
                                                <button class="btn btn-outline-secondary btn-sm" disabled>
                                                    Enrolled
                                                </button>
                                            }
                                            else if (sessionFull)
                                            {
                                                <button class="btn btn-danger btn-sm" disabled>
                                                    Full
                                                </button>
                                            }
                                            else if (prerequisiteMissing)
                                            {
                                                <button class="btn btn-warning btn-sm" disabled>
                                                    Need Prerequisite
                                                </button>
                                            }
                                            else
                                            {
                                                <form asp-controller="Enrollments" asp-action="Enroll" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="sessionId" value="@session.SessionId" />
                                                    <button class="btn btn-success btn-sm">
                                                        Enroll
                                                    </button>
                                                </form>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No sessions available</p>
                }

            </div>
        </div>
    }

</div>

<!-- SIGNALR SCRIPT -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("https://localhost:7258/enrollmentHub") // API URL
            .build();

        connection.on("EnrollmentUpdated", function (sessionId, availableSeats) {
            const seatCell = document.getElementById("seats-" + sessionId);
            if (seatCell) {
                seatCell.textContent = availableSeats;
            }
        });

        connection.start()
            .then(() => console.log("Connected to SignalR"))
            .catch(err => console.error(err.toString()));
    </script>
}