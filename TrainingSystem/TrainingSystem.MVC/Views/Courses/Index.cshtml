
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/enrollmentHub")
        .build();

    connection.on("ReceiveSeatsUpdate", function (sessionId, seats) {
        const el = document.getElementById("seats-" + sessionId);
        if (el) el.innerText = seats;
    });

    connection.start();
</script>
@model IEnumerable<TrainingSystem.API.Models.Course>

@{
    var roleId = Context.Session.GetInt32("RoleId");
}

<h2>Courses</h2>

@foreach (var course in Model)
{
    <div class="card mb-3 p-3">

        <h4>@course.Title</h4>
        <p>@course.Category?.CategoryName</p>

        <h5>Available Sessions</h5>

        <table class="table table-sm">
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Seats</th>
                <th></th>
            </tr>

            @foreach (var session in course.CourseSessions)
            {
                <tr>
                    <td>@session.SessionDate.ToShortDateString()</td>
                    <td>@session.StartTime - @session.EndTime</td>

                    <!-- 🔥 THIS IS IMPORTANT -->
                    <td id="seats-@session.SessionId">
                        @session.AvailableSeats
                    </td>

                    <td>
                        @if (roleId == 1)
                        {
                            <form asp-controller="Enrollments"
                                  asp-action="Enroll"
                                  method="post">

                                <input type="hidden" name="sessionId" value="@session.SessionId" />

                                <button class="btn btn-success btn-sm"
                                        @(session.AvailableSeats == 0 ? "disabled" : "")>
                                    Enroll
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </table>

    </div>
}