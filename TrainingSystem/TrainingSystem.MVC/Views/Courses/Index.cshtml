@model IEnumerable<TrainingSystem.API.Models.Course>

@{
    ViewData["Title"] = "Courses";
    var roleId = Context.Session.GetInt32("RoleId");
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Courses</h2>
            <p class="text-muted mb-0">Manage courses in the system.</p>
        </div>

        @if (roleId == 3)
        {
            <a asp-action="Create" class="btn text-white fw-semibold"
               style="background-color: #0a1f5c; border-radius: 10px;">
                Add Course
            </a>
        }
    </div>

    @foreach (var course in Model)
    {
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 18px;">
            <div class="card-body p-4">

                <!-- Course Title -->
                <h4 class="fw-bold mb-3" style="color: #0a1f5c;">
                    @course.Title
                </h4>

                <!-- Course Info -->
                <div class="d-flex flex-wrap gap-2 mb-3">

                    <span class="badge bg-light text-dark px-3 py-2">
                        Category: @course.Category?.CategoryName
                    </span>

                    <span class="badge bg-light text-dark px-3 py-2">
                        Duration: @course.DurationHours hrs
                    </span>

                    <span class="badge bg-light text-dark px-3 py-2">
                        Capacity: @course.DefaultCapacity
                    </span>

                    <span class="badge bg-light text-dark px-3 py-2">
                        Fee: @course.EnrollmentFee
                    </span>

                    @if (course.PrerequisiteCourse != null)
                    {
                        <span class="badge bg-danger-subtle text-danger px-3 py-2">
                            Prerequisite: @course.PrerequisiteCourse.Title
                        </span>
                    }
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(course.Description))
                {
                    <p class="text-muted mb-3">
                        @course.Description
                    </p>
                }

                <!-- Coordinator Actions -->
                @if (roleId == 3)
                {
                    <div class="d-flex gap-2">

                        <a asp-action="Edit" asp-route-id="@course.CourseId"
                           class="btn btn-sm btn-primary">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@course.CourseId"
                           class="btn btn-sm btn-danger">
                            Delete
                        </a>

                    </div>
                }

            </div>
        </div>
    }

</div>