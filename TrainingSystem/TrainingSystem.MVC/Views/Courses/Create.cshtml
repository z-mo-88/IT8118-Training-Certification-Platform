@model TrainingSystem.API.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-9">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold mb-4" style="color: #0a1f5c;">
                        Create Course
                    </h3>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                    }

                    <form asp-action="Create" method="post">

                        <!-- TITLE -->
                        <div class="mb-3">
                            <label class="fw-semibold">Title</label>
                            <input asp-for="Title" class="form-control" />
                        </div>

                        <!-- DESCRIPTION -->
                        <div class="mb-3">
                            <label class="fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control"></textarea>
                        </div>

                        <!-- CATEGORY  -->
                        <div class="mb-3">
                            <label class="fw-semibold">Category</label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="form-select">
                            </select>

                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <!-- NUMBERS -->
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label>Duration</label>
                                <input asp-for="DurationHours" class="form-control" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Capacity</label>
                                <input asp-for="DefaultCapacity" class="form-control" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label>Fee</label>
                                <input asp-for="EnrollmentFee" class="form-control" />
                            </div>
                        </div>

                        <!-- PREREQUISITE -->
                        <div class="mb-3">
                            <label>Prerequisite</label>
                            <select asp-for="PrerequisiteCourseId"
                                    asp-items="ViewBag.Courses"
                                    class="form-select">
                                <option value="">None</option>
                            </select>
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-light">Back</a>
                            <button class="btn btn-primary">Create</button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>