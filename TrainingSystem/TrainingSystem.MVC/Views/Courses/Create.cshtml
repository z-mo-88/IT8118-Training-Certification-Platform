@model TrainingSystem.API.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<h2>Create Course</h2>

<form asp-action="Create">
    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Duration (Hours)</label>
        <input asp-for="DurationHours" class="form-control" />
    </div>

    <div class="form-group">
        <label>Default Capacity</label>
        <input asp-for="DefaultCapacity" class="form-control" />
    </div>

    <div class="form-group">
        <label>Enrollment Fee</label>
        <input asp-for="EnrollmentFee" class="form-control" />
    </div>

    <div class="form-group">
        <label>Prerequisite Course</label>
        <select asp-for="PrerequisiteCourseId" asp-items="ViewBag.Courses" class="form-control">
            <option value="">None</option>
        </select>
    </div>

    <br />
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

<div asp-validation-summary="All" class="text-danger"></div>