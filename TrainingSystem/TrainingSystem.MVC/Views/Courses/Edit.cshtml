@model TrainingSystem.API.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-9">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">

                <div class="card-body p-4 p-lg-5">
                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Edit Course</h3>
                        <p class="text-muted mb-0">Update the course details below.</p>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CourseId" />

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold" style="color: #0a1f5c;">Title</label>
                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Enter course title"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold" style="color: #0a1f5c;">Description</label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      placeholder="Enter course description"
                                      style="border-radius: 10px; min-height: 100px;"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold" style="color: #0a1f5c;">Category</label>
                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="DurationHours" class="form-label fw-semibold" style="color: #0a1f5c;">Duration</label>
                                <input asp-for="DurationHours"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="DurationHours" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="DefaultCapacity" class="form-label fw-semibold" style="color: #0a1f5c;">Capacity</label>
                                <input asp-for="DefaultCapacity"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="DefaultCapacity" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="EnrollmentFee" class="form-label fw-semibold" style="color: #0a1f5c;">Fee</label>
                                <input asp-for="EnrollmentFee"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="EnrollmentFee" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PrerequisiteCourseId" class="form-label fw-semibold" style="color: #0a1f5c;">Prerequisite</label>
                            <select asp-for="PrerequisiteCourseId"
                                    asp-items="ViewBag.Courses"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                                <option value="">None</option>
                            </select>
                            <span asp-validation-for="PrerequisiteCourseId" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn fw-semibold px-4 text-white"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Save Changes
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}