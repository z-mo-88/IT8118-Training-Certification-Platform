@model TrainingSystem.API.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<h2>Edit Course</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="CourseId" />

    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Category</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Duration</label>
        <input asp-for="DurationHours" class="form-control" />
    </div>

    <div class="form-group">
        <label>Capacity</label>
        <input asp-for="DefaultCapacity" class="form-control" />
    </div>

    <div class="form-group">
        <label>Fee</label>
        <input asp-for="EnrollmentFee" class="form-control" />
    </div>

    <div class="form-group">
        <label>Prerequisite</label>
        <select asp-for="PrerequisiteCourseId" asp-items="ViewBag.Courses" class="form-control">
            <option value="">None</option>
        </select>
    </div>

    <br />
    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

<div asp-validation-summary="All" class="text-danger"></div>