@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrollments";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">My Enrollments</h2>
        <p class="text-muted mb-0">Track your enrolled courses, progress, and payment status.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Course</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Session Date</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Remaining Balance</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Payment Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Overdue</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                var remainingBalance = item.OutstandingBalance;

                                var paymentStatus = item.Status == "Dropped"
                                ? "Cancelled"
                                : remainingBalance <= 0
                                ? "Paid"
                                : "Partial";

                                var isOverdue = item.Status == "Dropped"
                                ? false
                                : remainingBalance > 0 &&
                                item.Session != null &&
                                item.Session.SessionDate < DateOnly.FromDateTime(DateTime.Now);

                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Session?.Course?.Title
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Session?.SessionDate.ToShortDateString()
                                    </td>

                                    <td class="py-3">
                                        @{
                                            string statusStyle = item.Status switch
                                            {
                                                "Completed" => "background-color: #198754; color: white; font-weight: 600;",
                                                "Dropped" => "background-color: #dc3545; color: white; font-weight: 600;",
                                                "Confirmed" => "background-color: #0d6efd; color: white; font-weight: 600;",
                                                "Attending" => "background-color: #20c997; color: white; font-weight: 600;",
                                                _ => "background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;"
                                            };
                                        }

                                        <span class="badge rounded-pill px-3 py-2" style="@statusStyle">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td class="py-3 fw-semibold"
                                        style="color:@(item.Status == "Dropped" ? "#6c757d" : remainingBalance > 0 ? "#dc3545" : "#198754")">
                                        @(item.Status == "Dropped" ? "-" : remainingBalance)
                                    </td>

                                    <td class="py-3">
                                        @if (paymentStatus == "Paid")
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Paid
                                            </span>
                                        }
                                        else if (paymentStatus == "Cancelled")
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #6c757d; color: white;">
                                                Cancelled
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #ffc107; color: #212529;">
                                                Partial / Unpaid
                                            </span>
                                        }
                                    </td>

                                    <td class="py-3">
                                        @if (item.Status == "Dropped")
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #6c757d; color: white;">
                                                N/A
                                            </span>
                                        }
                                        else if (isOverdue)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #dc3545; color: white;">
                                                Overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                OK
                                            </span>
                                        }
                                    </td>

                                    <td class="py-3 text-center">
                                        @if (item.Status == "Enrolled")
                                        {
                                            <a asp-action="Drop"
                                               asp-route-id="@item.EnrollmentId"
                                               class="btn btn-sm fw-semibold text-white px-3"
                                               style="background-color: #dc3545; border-radius: 10px; border: none;"
                                               onclick="return confirm('Are you sure you want to drop this course?');">
                                                Drop
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    No enrollments found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>