@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrollments";
}

<h2>My Enrollments</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Course</th>
            <th>Session Date</th>
            <th>Status</th>
            <th>Balance</th>
            <th>Overdue</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Session?.Course?.Title</td>
                <td>@item.Session?.SessionDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@item.OutstandingBalance</td>
                <td>
                    @if (item.IsOverdue)
                    {
                        <span class="text-danger">Yes</span>
                    }
                    else
                    {
                        <span>No</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>