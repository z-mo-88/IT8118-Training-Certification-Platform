@model IEnumerable<TrainingSystem.API.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrollments";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">My Enrollments</h2>
        <p class="text-muted mb-0">Track your enrolled courses and payment status.</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Course</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Session Date</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Balance</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Overdue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Session?.Course?.Title
                                    </td>

                                    <td class="py-3">
                                        @item.Session?.SessionDate.ToShortDateString()
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td class="py-3 fw-semibold"
                                        style="color: @(item.OutstandingBalance > 0 ? "#dc3545" : "#198754");">
                                        @item.OutstandingBalance
                                    </td>

                                    <td class="py-3">
                                        @if (item.IsOverdue)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #dc3545; color: white;">
                                                Overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                OK
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No enrollments found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>