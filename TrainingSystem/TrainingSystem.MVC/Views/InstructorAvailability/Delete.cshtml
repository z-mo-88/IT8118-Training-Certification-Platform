@model TrainingSystem.API.Models.InstructorAvailability

@{
    ViewData["Title"] = "Delete Availability";
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2 text-danger">Delete Availability</h3>
                        <p class="text-muted mb-0">
                            Are you sure you want to delete this availability record?
                        </p>
                    </div>

                    <div class="mb-4 p-3 rounded-3" style="background-color: #f8f9fc;">
                        <div class="mb-2">
                            <span class="fw-semibold" style="color: #0a1f5c;">Day:</span>
                            <span class="text-muted">@Model.DayOfWeek</span>
                        </div>

                        <div class="mb-2">
                            <span class="fw-semibold" style="color: #0a1f5c;">Start:</span>
                            <span class="text-muted">@Model.StartTime.ToString(@"hh\:mm")</span>
                        </div>

                        <div>
                            <span class="fw-semibold" style="color: #0a1f5c;">End:</span>
                            <span class="text-muted">@Model.EndTime.ToString(@"hh\:mm")</span>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="AvailabilityId" type="hidden" />
                        <input type="hidden" name="userId" value="@targetUserId" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               asp-route-userId="@targetUserId"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #dc3545; height: 48px; border-radius: 10px; border: none;">
                                Delete
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>