

@model IEnumerable<TrainingSystem.API.Models.InstructorAvailability>
@using System.Security.Claims

@{
    var roleId = Context.Session.GetInt32("RoleId");
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4 d-flex justify-content-between align-items-center">

        <div>
            <h2 class="fw-bold" style="color:#0a1f5c;">Availability</h2>
            <p class="text-muted">Manage availability schedule</p>
        </div>

        @if (roleId == 3) {
        <a href="/Instructor" class="btn btn-outline-secondary mb-3">
            Back to Instructors
        </a>
        }

        <!-- ADD  -->
        <a asp-action="Create"
           asp-route-userId="@targetUserId"
           class="btn text-white"
           style="background:#0a1f5c; border-radius:10px;">
            Add Availability
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius:18px;">
        <div class="table-responsive">
            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Day</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Available</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DayOfWeek</td>
                            <td>@item.StartTime</td>
                            <td>@item.EndTime</td>

                            <td>
                                <span class="badge @(item.IsAvailable ? "bg-success" : "bg-secondary")">
                                    @(item.IsAvailable ? "Available" : "Not Available")
                                </span>
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">

                                    <!-- EDIT -->
                                    <a asp-action="Edit"
                                       asp-route-id="@item.AvailabilityId"
                                       asp-route-userId="@targetUserId"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <!-- DELETE -->
                                    @if (roleId == 3)
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.AvailabilityId"
                                           asp-route-userId="@targetUserId"
                                           class="btn btn-danger btn-sm">
                                            Delete
                                        </a>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>