@model IEnumerable<TrainingSystem.API.Models.InstructorAvailability>

@{
    ViewData["Title"] = "My Availability";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">My Availability</h2>
            <p class="text-muted mb-0">Manage your available schedule.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create"
               class="btn text-white fw-semibold px-4"
               style="background-color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                Add Availability
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Day</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Start</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">End</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Available</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c; width: 160px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.DayOfWeek
                                    </td>

                                    <td class="py-3">
                                        @item.StartTime.ToString(@"hh\:mm")
                                    </td>

                                    <td class="py-3">
                                        @item.EndTime.ToString(@"hh\:mm")
                                    </td>

                                    <td class="py-3">
                                        @if (item.IsAvailable)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Available
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #6c757d; color: white;">
                                                Not Available
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center py-3">
                                        <a asp-action="Delete"
                                           asp-route-id="@item.AvailabilityId"
                                           class="btn btn-sm fw-semibold px-3 text-white"
                                           style="background-color: #dc3545; border-radius: 10px; border: none;">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No availability added yet.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>