@model IEnumerable<TrainingSystem.API.Models.InstructorAvailability>
@using Microsoft.AspNetCore.Http

@{
    var targetUserId = ViewBag.TargetUserId;
    var roleId = Context.Session.GetInt32("RoleId");

    ViewData["Title"] = roleId == 3 ? "Edit Availability" : "My Availability";

    var pageTitle = roleId == 3 ? "Edit Availability" : "My Availability";
    var pageSubtitle = roleId == 3
        ? "Manage Instructor Availability Schedule."
        : "Manage your available schedule.";
}

<div class="container-fluid py-5 px-3 px-md-5">

    @if (roleId == 3)
    {
        <a href="javascript:history.back()"
           class="btn btn-light fw-semibold"
           style="border-radius: 10px;">
            Back
        </a>
    }

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">@pageTitle</h2>
            <p class="text-muted mb-0">@pageSubtitle</p>
        </div>

        <a asp-action="Create"
           asp-route-userId="@targetUserId"
           class="btn text-white fw-semibold px-4"
           style="background-color: #0a1f5c; border-radius: 10px; border: none;">
            Add Availability
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 18px;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="px-4 py-3">Day</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Available</th>
                            @if (roleId == 3)
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">
                                        @item.DayOfWeek
                                    </td>

                                    <td class="text-muted">
                                        @item.StartTime
                                    </td>

                                    <td class="text-muted">
                                        @item.EndTime
                                    </td>

                                    <td>
                                        @if (item.IsAvailable)
                                        {
                                            <span class="badge bg-success px-3 py-2">Available</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2">Not Available</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (roleId == 3)
                                        {
                                            <a asp-action="Delete"
                                            asp-route-id="@item.AvailabilityId"
                                            asp-route-userId="@targetUserId"
                                            class="btn btn-sm fw-semibold text-white px-3"
                                            style="background-color: #dc3545; border-radius: 10px; border: none;">
                                                Delete
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    No availability records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>