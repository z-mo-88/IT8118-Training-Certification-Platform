@model IEnumerable<TrainingSystem.API.Models.InstructorAvailability>
@using System.Security.Claims

@{
    var roleId = Context.Session.GetInt32("RoleId");
    var targetUserId = ViewBag.TargetUserId;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#0a1f5c;">Availability</h2>
            <p class="text-muted mb-0">Manage availability schedule.</p>
        </div>

        <div class="mt-3 mt-md-0 d-flex gap-2">
            @if (roleId == 3)
            {
                <a href="/Instructor"
                   class="btn fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                   style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px; line-height:1;">
                    Back to Instructors
                </a>
            }

            <a asp-action="Create"
               asp-route-userId="@targetUserId"
               class="btn text-white fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
               style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px; line-height:1;">
                Add Availability
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:18px; overflow:hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color:rgba(10,31,92,0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color:#0a1f5c;">Day</th>
                            <th class="fw-semibold py-3" style="color:#0a1f5c;">Start</th>
                            <th class="fw-semibold py-3" style="color:#0a1f5c;">End</th>
                            <th class="fw-semibold py-3" style="color:#0a1f5c;">Available</th>
                            <th class="fw-semibold py-3 text-center" style="color:#0a1f5c;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">@item.DayOfWeek</td>
                                <td class="py-3 text-muted">@item.StartTime</td>
                                <td class="py-3 text-muted">@item.EndTime</td>

                                <td class="py-3">
                                    <span class="badge rounded-pill px-3 py-2 @(item.IsAvailable ? "bg-success" : "bg-secondary")">
                                        @(item.IsAvailable ? "Available" : "Not Available")
                                    </span>
                                </td>

                                <td class="text-center py-3">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.AvailabilityId"
                                           asp-route-userId="@targetUserId"
                                           class="btn btn-sm fw-semibold px-3"
                                           style="background-color:#ffc107; border-radius:10px; border:none; color:#212529;">
                                            Edit
                                        </a>

                                        @if (roleId == 3)
                                        {
                                            <a asp-action="Delete"
                                               asp-route-id="@item.AvailabilityId"
                                               asp-route-userId="@targetUserId"
                                               class="btn btn-sm fw-semibold px-3 text-white"
                                               style="background-color:#dc3545; border-radius:10px; border:none;">
                                                Delete
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>