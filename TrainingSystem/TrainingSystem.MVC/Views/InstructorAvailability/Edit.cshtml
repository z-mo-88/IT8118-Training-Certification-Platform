
@model TrainingSystem.API.Models.InstructorAvailability
@using System.Security.Claims

@{
    var roleId = Context.Session.GetInt32("RoleId");
}

<div class="container py-5">
    <div class="card shadow-sm border-0" style="border-radius:18px;">
        <div class="card-body p-5">

            <h3>Edit Availability</h3>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="AvailabilityId" />
                <input type="hidden" asp-for="UserId" />

                <div class="mb-3">
                    <label>Day</label>
                    <select asp-for="DayOfWeek" class="form-select">
                        <option>Sunday</option>
                        <option>Monday</option>
                        <option>Tuesday</option>
                        <option>Wednesday</option>
                        <option>Thursday</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Start</label>
                    <input asp-for="StartTime" type="time" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>End</label>
                    <input asp-for="EndTime" type="time" class="form-control" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index"
                       asp-route-userId="@Model.UserId"
                       class="btn px-4"
                       style="background-color: #f1f3f5; border-radius: 10px;">
                        Cancel
                    </a>

                <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>