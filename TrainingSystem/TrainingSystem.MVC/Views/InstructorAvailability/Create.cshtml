@model TrainingSystem.API.Models.InstructorAvailability
@using Microsoft.AspNetCore.Http

@{
    var roleId = Context.Session.GetInt32("RoleId");

    ViewData["Title"] = roleId == 3 ? "Add Availability" : "Add Availability";

    var pageTitle = roleId == 3 ? "Add Availability" : "Add Availability";
    var pageSubtitle = roleId == 3
        ? "Add a new availability schedule for the instructor."
        : "Add your availability schedule.";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color:#0a1f5c;">@pageTitle</h3>
                        <p class="text-muted mb-0">@pageSubtitle</p>
                    </div>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

                        <div class="mb-3">
                            <label asp-for="DayOfWeek" class="form-label fw-semibold" style="color:#0a1f5c;">Day</label>
                            <select asp-for="DayOfWeek" class="form-select" style="height:50px; border-radius:10px;">
                                <option value="">-- Select Day --</option>
                                <option>Sunday</option>
                                <option>Monday</option>
                                <option>Tuesday</option>
                                <option>Wednesday</option>
                                <option>Thursday</option>
                                <option>Friday</option>
                                <option>Saturday</option>
                            </select>
                            <span asp-validation-for="DayOfWeek" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StartTime" class="form-label fw-semibold" style="color:#0a1f5c;">Start Time</label>
                            <input asp-for="StartTime" type="time" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EndTime" class="form-label fw-semibold" style="color:#0a1f5c;">End Time</label>
                            <input asp-for="EndTime" type="time" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               asp-route-userId="@Model.UserId"
                               class="btn fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px; line-height:1;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-inline-flex align-items-center justify-content-center"
                                    style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px; line-height:1;">
                                Save
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}