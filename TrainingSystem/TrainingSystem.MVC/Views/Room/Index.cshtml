@model IEnumerable<TrainingSystem.API.Models.Room>

@{
    ViewData["Title"] = "Rooms";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#0a1f5c;">Rooms</h2>
            <p class="text-muted mb-0">Manage available rooms and capacities.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create"
               class="btn text-white fw-semibold px-4 d-flex align-items-center justify-content-center"
               style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px;">
                Add Room
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 mb-4">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius:18px; overflow:hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color:rgba(10,31,92,0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color:#0a1f5c;">Name</th>
                            <th class="fw-semibold py-3" style="color:#0a1f5c;">Capacity</th>
                            <th class="fw-semibold py-3" style="color:#0a1f5c;">Location</th>
                            <th class="fw-semibold py-3 text-center" style="color:#0a1f5c; width:220px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color:#0a1f5c;">
                                        @item.RoomName
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color:rgba(10,31,92,0.08); color:#0a1f5c;">
                                            @item.Capacity
                                        </span>
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Location
                                    </td>

                                    <td class="text-center py-3">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Edit"
                                               asp-route-id="@item.RoomId"
                                               class="btn btn-sm fw-semibold px-3 text-white"
                                               style="background-color:#0a1f5c; border-radius:10px; border:none;">
                                                Edit
                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.RoomId"
                                               class="btn btn-sm fw-semibold px-3 text-white"
                                               style="background-color:#dc3545; border-radius:10px; border:none;">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    No rooms found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>