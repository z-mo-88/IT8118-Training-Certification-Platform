@model TrainingSystem.API.Models.Room

@{
    ViewData["Title"] = "Edit Room";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Edit Room</h3>
                        <p class="text-muted mb-0">Update room information.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="Edit" method="post">
                        <input asp-for="RoomId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="RoomName" class="form-label fw-semibold" style="color:#0a1f5c;">Room Name</label>
                            <input asp-for="RoomName"
                                   class="form-control"
                                   style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="RoomName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label fw-semibold" style="color:#0a1f5c;">Capacity</label>
                            <input asp-for="Capacity"
                                   type="number"
                                   min="1"
                                   class="form-control"
                                   style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Location" class="form-label fw-semibold" style="color:#0a1f5c;">Location</label>
                            <input asp-for="Location"
                                   class="form-control"
                                   style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn fw-semibold px-4 d-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-flex align-items-center justify-content-center"
                                    style="background-color:#0a1f5c; height:46px; border-radius:10px; border:none;">
                                Save Changes
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}