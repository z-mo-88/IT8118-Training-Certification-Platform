<h2>Assign Course to Track</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label>Track</label>
        <select name="trackId" class="form-control">
            @foreach (var t in ViewBag.Tracks)
            {
                <option value="@t.CertificationTrackId">@t.TrackName</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Course</label>
        <select name="courseId" class="form-control">
            @foreach (var c in ViewBag.Courses)
            {
                <option value="@c.CourseId">@c.Title</option>
            }
        </select>
    </div>

    <div class="form-check mb-3">
        <input type="checkbox" name="isRequired" value="true" class="form-check-input" id="isRequired" />
        <label class="form-check-label" for="isRequired">Required</label>
    </div>

    <button type="submit" class="btn btn-primary">Assign</button>
</form>