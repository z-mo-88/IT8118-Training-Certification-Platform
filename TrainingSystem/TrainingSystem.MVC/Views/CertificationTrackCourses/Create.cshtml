<h2>Assign Course to Track</h2>

<form asp-action="Create">

    <div class="mb-3">
        <label>Track</label>
        <select name="trackId" class="form-control" required>
            <option value="" disabled selected>-- Choose a track --</option>

            @foreach (var t in ViewBag.Tracks)
            {
                <option value="@t.CertificationTrackId">@t.TrackName</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Course</label>
        <select name="courseId" class="form-control" required>
            <option value="" disabled selected>-- Choose a course --</option>

            @foreach (var c in ViewBag.Courses)
            {
                <option value="@c.CourseId">@c.Title</option>
            }
        </select>
    </div>

    <div class="form-check mb-3">
        <input type="checkbox" name="isRequired" class="form-check-input" />
        <label class="form-check-label">Required</label>
    </div>

    <div class="mt-3">
    <button type="submit" class="btn btn-primary">Assign</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">
        Cancel
    </a>
    </div>
</form>