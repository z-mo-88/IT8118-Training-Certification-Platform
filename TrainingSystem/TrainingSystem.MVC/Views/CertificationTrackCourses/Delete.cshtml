<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">

            <div class="card border-0 shadow-sm text-center" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold text-danger mb-3">Delete Assignment</h3>
                    <p class="text-muted mb-4">Are you sure you want to remove this course?</p>

                    <div class="mb-4">
                        <div class="fw-semibold" style="color:#0a1f5c;">
                            @Model.CertificationTrack.TrackName
                        </div>
                        <div class="text-muted">@Model.Course.Title</div>
                    </div>

                    <form asp-action="Delete">

                        <input type="hidden" name="trackId" value="@Model.CertificationTrackId" />
                        <input type="hidden" name="courseId" value="@Model.CourseId" />

                        <div class="d-flex justify-content-center gap-3">

                            <a asp-action="Index"
                               class="btn"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn text-white"
                                    style="background:#dc3545; border-radius:10px;">
                                Delete
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>