<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold mb-4 text-center" style="color:#0a1f5c;">
                        Edit Track Course
                    </h3>

                    <form asp-action="Edit" method="post">

                        <input type="hidden" name="trackId" value="@Model.CertificationTrackId" />
                        <input type="hidden" name="courseId" value="@Model.CourseId" />

                        <div class="mb-3">
                            <label class="fw-semibold mb-1">Course</label>
                            <select name="newCourseId" class="form-select" style="border-radius:10px;">
                                @foreach (var c in ViewBag.Courses)
                                {
                                    <option value="@c.CourseId"
                                            selected="@(c.CourseId == Model.CourseId)">
                                        @c.Title
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="fw-semibold mb-1">Track</label>
                            <input class="form-control"
                                   value="@Model.CertificationTrack?.TrackName"
                                   style="border-radius:10px;" />
                        </div>

                        <div class="form-check mb-4">
                            <input type="checkbox"
                                   name="isRequired"
                                   value="true"
                                   class="form-check-input"
                                   id="isRequired"
                                   @(Model.IsRequired ? "checked" : "") />
                            <label class="form-check-label" for="isRequired">Required</label>
                        </div>

                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                               class="btn"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn text-white"
                                    style="background:#0a1f5c; border-radius:10px;">
                                Save Changes
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>