<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold" style="color:#0a1f5c;">Track Courses</h3>

        <a asp-action="Create"
           class="btn text-white"
           style="background-color:#0a1f5c; border-radius:10px; font-weight:600;">
            + Assign Course
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">

            @foreach (var item in Model)
            {
                <div class="d-flex justify-content-between align-items-center mb-3 p-3"
                     style="border:1px solid #e9ecef; border-radius:12px;">

                    <div>
                        <div class="fw-semibold" style="color:#0a1f5c;">
                            @item.CertificationTrack.TrackName
                        </div>
                        <div class="text-muted">@item.Course.Title</div>
                    </div>

                    <div class="d-flex align-items-center gap-3">

                        <span class="badge px-3 py-2"
                              style="background:@(item.IsRequired ? "#198754" : "#6c757d");">
                            @(item.IsRequired ? "Required" : "Optional")
                        </span>

                        <div class="d-flex gap-2">

                            <a asp-action="Edit"
                               asp-route-trackId="@item.CertificationTrackId"
                               asp-route-courseId="@item.CourseId"
                               class="btn btn-sm"
                               style="background:#ffc107; border-radius:8px;">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-trackId="@item.CertificationTrackId"
                               asp-route-courseId="@item.CourseId"
                               class="btn btn-sm text-white"
                               style="background:#dc3545; border-radius:8px;">
                                Delete
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    </div>

</div>