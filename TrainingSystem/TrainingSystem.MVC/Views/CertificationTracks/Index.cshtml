@model IEnumerable<TrainingSystem.API.Models.CertificationTrack>

<h2>Certification Tracks</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Add Track</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Track Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TrackName</td>
                <td>@item.Description</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.CertificationTrackId"
                       class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Delete"
                       asp-route-id="@item.CertificationTrackId"
                       class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>