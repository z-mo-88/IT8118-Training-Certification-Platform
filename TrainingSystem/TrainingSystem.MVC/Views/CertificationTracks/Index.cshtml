@model IEnumerable<TrainingSystem.API.Models.CertificationTrack>

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1" style="color:#0a1f5c;">Certification Tracks</h3>
            <p class="text-muted mb-0">Manage certification tracks.</p>
        </div>

        <a asp-action="Create"
           class="btn text-white"
           style="background-color:#0a1f5c; border-radius:10px; font-weight:600;">
            + Add Track
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">

            @foreach (var item in Model)
            {
                <div class="d-flex justify-content-between align-items-center mb-3 p-3"
                     style="border:1px solid #e9ecef; border-radius:12px;">

                    <div>
                        <div class="fw-semibold" style="color:#0a1f5c;">
                            @item.TrackName
                        </div>
                        <div class="text-muted small">
                            @item.Description
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Edit"
                           asp-route-id="@item.CertificationTrackId"
                           class="btn btn-sm"
                           style="background:#ffc107; border-radius:8px;">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.CertificationTrackId"
                           class="btn btn-sm text-white"
                           style="background:#dc3545; border-radius:8px;">
                            Delete
                        </a>
                    </div>

                </div>
            }

        </div>
    </div>

</div>