@model TrainingSystem.API.Models.CertificationTrack

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Create Certification Track</h3>
                    <p class="text-muted mb-4">Add a new certification track.</p>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
                    }

                    <form asp-action="Create">
                        <div class="mb-3">
                            <label class="fw-semibold mb-1">Track Name</label>
                            <input asp-for="TrackName" class="form-control" style="border-radius:10px;" />
                        </div>

                        <div class="mb-4">
                            <label class="fw-semibold mb-1">Description</label>
                            <input asp-for="Description" class="form-control" style="border-radius:10px;" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index"
                               class="btn"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white"
                                    style="background-color:#0a1f5c; border-radius:10px; font-weight:600;">
                                Create
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>