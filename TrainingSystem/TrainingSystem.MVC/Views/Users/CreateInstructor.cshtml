@model TrainingSystem.API.Models.User

@{
    ViewData["Title"] = "Add Instructor";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Add Instructor</h3>
                        <p class="text-muted mb-0">Enter instructor details below.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All"
                             class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="CreateInstructor" method="post">

                        <div class="mb-3">
                            <label asp-for="Name"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;"></label>
                            <input asp-for="Name"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;"></label>
                            <input asp-for="Email"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;"></label>
                            <input asp-for="PhoneNumber"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="PasswordHash"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Temporary Password</label>
                            <input asp-for="PasswordHash"
                                   type="password"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                        </div>

                        <input type="hidden" asp-for="RoleId" value="2" />
                        <input type="hidden" asp-for="IsActive" value="true" />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Create Instructor
                            </button>
                        </div>

                    </form>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}