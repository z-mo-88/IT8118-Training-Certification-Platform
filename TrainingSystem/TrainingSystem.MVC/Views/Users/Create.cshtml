@model TrainingSystem.API.Models.User

@{
    ViewData["Title"] = "Create Trainee";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Create Trainee</h3>
                        <p class="text-muted mb-0">Enter trainee details below.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold" style="color:#0a1f5c;">Name</label>
                            <input asp-for="Name" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold" style="color:#0a1f5c;">Email</label>
                            <input asp-for="Email" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordHash" class="form-label fw-semibold" style="color:#0a1f5c;">Password</label>
                            <input asp-for="PasswordHash" type="password" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold" style="color:#0a1f5c;">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" style="height:50px; border-radius:10px;" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <input type="hidden" asp-for="RoleId" value="1" />
                        <input type="hidden" asp-for="IsActive" value="true" />

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index"
                               class="btn fw-semibold px-4 d-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-flex align-items-center justify-content-center"
                                    style="background-color:#0a1f5c; border-radius:10px; border:none; height:46px;">
                                Create
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}