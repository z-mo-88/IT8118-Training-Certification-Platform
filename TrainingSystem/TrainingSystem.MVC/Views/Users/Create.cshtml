@model TrainingSystem.API.Models.User

@{
    ViewData["Title"] = "Create User";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-6">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4 text-center">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Create User</h3>
                        <p class="text-muted mb-0">Enter the new user details below.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All"
                             class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Name"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Name</label>
                            <input asp-for="Name"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Email</label>
                            <input asp-for="Email"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordHash"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Password</label>
                            <input asp-for="PasswordHash"
                                   class="form-control"
                                   type="password"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Phone Number</label>
                            <input asp-for="PhoneNumber"
                                   class="form-control"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RoleId"
                                   class="form-label fw-semibold"
                                   style="color: #0a1f5c;">Role</label>
                            <select asp-for="RoleId"
                                    asp-items="ViewBag.Roles"
                                    class="form-select"
                                    style="height: 50px; border-radius: 10px;">
                                <option value="">Select Role</option>
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive"
                                   class="form-check-label fw-semibold"
                                   style="color: #0a1f5c;">Active</label>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back to List
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Save
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}