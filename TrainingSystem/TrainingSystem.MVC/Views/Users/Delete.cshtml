@model TrainingSystem.API.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-6">

            <div class="card border-0 shadow-sm" style="border-radius: 18px;">
                <div class="card-body p-4 p-lg-5 text-center">

                    <h3 class="fw-bold mb-3" style="color: #0a1f5c;">Delete User</h3>

                    <div class="alert alert-danger rounded-3 mb-4">
                        <strong>Are you sure?</strong><br />
                        This user will be permanently deleted.
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-semibold mb-3" style="color: #0a1f5c;">
                            @Model.Name
                        </h5>

                        <div class="d-flex flex-column gap-2 text-muted">

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">User ID</span>
                                <span>@Model.UserId</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Email</span>
                                <span>@Model.Email</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Phone</span>
                                <span>@Model.PhoneNumber</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Role ID</span>
                                <span>@Model.RoleId</span>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold" style="color: #0a1f5c;">Active</span>
                                <span>
                                    @(Model.IsActive ? "Yes" : "No")
                                </span>
                            </div>

                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="UserId" />

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold px-4"
                               style="border-radius: 10px;">
                                Back to List
                            </a>

                            <button type="submit"
                                    class="btn fw-semibold px-4 text-white"
                                    style="background-color: #dc3545; border-radius: 10px; border: none;">
                                Delete
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>