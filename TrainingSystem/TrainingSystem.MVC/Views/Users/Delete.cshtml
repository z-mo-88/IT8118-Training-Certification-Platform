@model TrainingSystem.API.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-6">

            <div class="card border-0 shadow-sm text-center" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h3 class="fw-bold text-danger mb-3">Delete User</h3>
                    <p class="text-muted mb-4">Are you sure you want to delete this user?</p>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3">
                            @TempData["Error"]
                        </div>
                    }

                    <div class="mb-4">
                        <h5 class="fw-semibold mb-3" style="color:#0a1f5c;">
                            @Model.Name
                        </h5>

                        <div class="text-start mx-auto" style="max-width:420px;">
                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <span class="fw-semibold" style="color:#0a1f5c;">User ID</span>
                                <span class="text-muted">@Model.UserId</span>
                            </div>

                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <span class="fw-semibold" style="color:#0a1f5c;">Email</span>
                                <span class="text-muted">@Model.Email</span>
                            </div>

                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <span class="fw-semibold" style="color:#0a1f5c;">Phone</span>
                                <span class="text-muted">@Model.PhoneNumber</span>
                            </div>

                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <span class="fw-semibold" style="color:#0a1f5c;">Role ID</span>
                                <span class="text-muted">@Model.RoleId</span>
                            </div>

                            <div class="d-flex justify-content-between py-2">
                                <span class="fw-semibold" style="color:#0a1f5c;">Active</span>
                                <span class="text-muted">
                                    @(Model.IsActive ? "Yes" : "No")
                                </span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="UserId" />

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a asp-action="Index"
                               class="btn fw-semibold px-4 d-flex align-items-center justify-content-center"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px; height:46px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4 d-flex align-items-center justify-content-center"
                                    style="background-color:#dc3545; border-radius:10px; border:none; height:46px;">
                                Delete
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>