@model IEnumerable<TrainingSystem.API.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Users</h2>
            <p class="text-muted mb-0">Manage trainee accounts.</p>
        </div>

       

            <a asp-action="CreateInstructor"
               class="btn fw-semibold px-4"
               style="background-color: rgba(10,31,92,0.1); color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                Add Instructor
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">User ID</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Name</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Email</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Phone</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Role</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c; width: 120px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 text-muted">
                                        @item.UserId
                                    </td>

                                    <td class="py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Name
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.Email
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.PhoneNumber
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10,31,92,0.08); color: #0a1f5c;">
                                            @item.Role?.RoleName
                                        </span>
                                    </td>

                                    <td class="py-3">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #198754; color: white;">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background-color: #6c757d; color: white;">
                                                Inactive
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center py-3">
                                        <a asp-action="Delete"
                                           asp-route-id="@item.UserId"
                                           class="btn btn-sm fw-semibold px-3 text-white"
                                           style="background-color: #dc3545; border-radius: 10px; border: none;">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    No users found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>