@model IEnumerable<TrainingSystem.API.Models.Certificate>

@{
    ViewData["Title"] = "My Certificates";
    var progressList = ViewBag.Progress as List<TrainingSystem.API.Models.TraineeCertificationProgress>;
}

<h2>My Certificates</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Track</th>
            <th>Status</th>
            <th>Issued Date</th>
            <th>Reference</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CertificationTrack?.TrackName</td>
                <td>@item.CertificateStatus</td>
                <td>@item.IssuedDate</td>
                <td>@item.CertificateReferenceNumber</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h3>Certification Progress</h3>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Track</th>
            <th>Status</th>
            <th>Progress %</th>
            <th>Eligible Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in progressList)
        {
            <tr>
                <td>@p.CertificationTrackId</td>
                <td>@p.Status</td>
                <td>@p.ProgressPercent %</td>
                <td>
                    @if (p.EligibleDate != DateOnly.MinValue)
                    {
                        @p.EligibleDate
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>