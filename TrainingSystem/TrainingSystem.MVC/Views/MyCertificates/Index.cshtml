@model IEnumerable<TrainingSystem.API.Models.Certificate>

@{
    ViewData["Title"] = "My Certificates";
    var progressList = ViewBag.Progress as List<TrainingSystem.API.Models.TraineeCertificationProgress>;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <div class="mb-4">
        <h2 class="fw-bold mb-1" style="color: #0a1f5c;">My Certificates</h2>
        <p class="text-muted mb-0">View your earned certificates and progress.</p>
    </div>

    <!-- Certificates Table -->
    <div class="card border-0 shadow-sm mb-5" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Track</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Issued Date</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Reference</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.CertificationTrack?.TrackName
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c;">
                                            @item.CertificateStatus
                                        </span>
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.IssuedDate
                                    </td>

                                    <td class="py-3 text-muted">
                                        @item.CertificateReferenceNumber
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    No certificates found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

    <!-- Progress Section -->
    <div class="mb-4">
        <h3 class="fw-bold mb-1" style="color: #0a1f5c;">Certification Progress</h3>
        <p class="text-muted mb-0">Track your progress toward certifications.</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Track</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Progress</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Eligible Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (progressList != null && progressList.Any())
                        {
                            @foreach (var p in progressList)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @p.CertificationTrackId
                                    </td>

                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c;">
                                            @p.Status
                                        </span>
                                    </td>

                                    <td class="py-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress w-100" style="height: 8px; border-radius: 10px;">
                                                <div class="progress-bar"
                                                     role="progressbar"
                                                     style="width: @p.ProgressPercent%; background-color: #0a1f5c;">
                                                </div>
                                            </div>
                                            <span class="small text-muted">@p.ProgressPercent%</span>
                                        </div>
                                    </td>

                                    <td class="py-3 text-muted">
                                        @if (p.EligibleDate != DateOnly.MinValue)
                                        {
                                            @p.EligibleDate
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    No progress data available.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>