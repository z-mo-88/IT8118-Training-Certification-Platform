@model IEnumerable<TrainingSystem.API.Models.TraineeCertificationProgress>

@{
    ViewData["Title"] = "My Certification Progress";
    var certs = ViewBag.Certificates as List<TrainingSystem.API.Models.Certificate>;
    var missingDict = ViewBag.MissingCourses as Dictionary<int, int>;
}

<div class="container-fluid py-5 px-3 px-md-5">

    <h2 class="mb-4 fw-bold" style="color:#0a1f5c;">
        My Certification Progress
    </h2>

    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            var cert = certs?.FirstOrDefault(c =>
            c.CertificationTrackId == item.CertificationTrackId);

            var missing = (missingDict != null && missingDict.ContainsKey(item.CertificationTrackId))
            ? missingDict[item.CertificationTrackId]
            : 0;

            <div class="card mb-4 border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <h5 class="fw-bold mb-3" style="color:#0a1f5c;">
                        @item.CertificationTrack?.TrackName
                    </h5>

                    <p><strong>Progress:</strong> @item.ProgressPercent %</p>

                    <div class="progress mb-3" style="height: 20px; border-radius:999px;">
                        <div class="progress-bar bg-success"
                             style="width:@item.ProgressPercent%; border-radius:999px;">
                            @item.ProgressPercent%
                        </div>
                    </div>

                    @if (missing > 0)
                    {
                        <div class="text-warning mt-2 mb-3">
                            You need @missing @(missing == 1 ? "more course" : "more courses") to complete this track
                        </div>
                    }

                    <p>
                        <strong>Status:</strong>
                        @if (item.Status == "Not Started")
                        {
                            <span class="badge bg-secondary rounded-pill px-3 py-2">Not Started</span>
                        }
                        else if (item.Status == "In Progress")
                        {
                            <span class="badge bg-info rounded-pill px-3 py-2">In Progress</span>
                        }
                        else
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2">Eligible</span>
                        }
                    </p>

                    @if (item.ProgressPercent == 100)
                    {
                        <p><strong>Eligible Date:</strong> @item.EligibleDate</p>
                    }

                    @if (item.ProgressPercent == 100)
                    {
                        if (cert != null)
                        {
                            <div class="alert alert-success mt-3 rounded-3">
                                🎓 <strong>Certificate Issued!</strong><br />

                                <div>Reference: <b>@cert.CertificateReferenceNumber</b></div>
                                <div>Issued Date: <b>@cert.IssuedDate</b></div>
                                <div>Status: <b>@cert.CertificateStatus</b></div>

                                <a asp-controller="Certificate"
                                   asp-action="Download"
                                   asp-route-id="@cert.CertificateId"
                                   class="btn mt-3 fw-semibold text-white px-4 d-inline-flex align-items-center justify-content-center"
                                   style="background-color:#0a1f5c; border-radius:12px; height:46px; line-height:1;">
                                    ⬇ Download Certificate
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mt-3 rounded-3">
                                Certificate is being generated...
                            </div>
                        }
                    }

                </div>
            </div>
        }
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:18px;">
            <div class="card-body text-center text-muted py-5">
                No certification progress found.
            </div>
        </div>
    }

</div>