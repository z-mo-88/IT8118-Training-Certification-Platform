@model IEnumerable<TrainingSystem.API.Models.TraineeCertificationProgress>

@{
    ViewData["Title"] = "My Certification Progress";
    var certs = ViewBag.Certificates as List<TrainingSystem.API.Models.Certificate>;
}

<div class="container py-5">

    <h2 class="mb-4 fw-bold" style="color:#0a1f5c;">
        My Certification Progress
    </h2>

    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            var cert = certs?.FirstOrDefault(c =>
            c.CertificationTrackId == item.CertificationTrackId);

            <div class="card mb-4 shadow-sm" style="border-radius:15px;">
                <div class="card-body">

                    <h5 class="fw-bold mb-3" style="color:#0a1f5c;">
                        @item.CertificationTrack?.TrackName
                    </h5>

                    <!-- Progress -->
                    <p><strong>Progress:</strong> @item.ProgressPercent %</p>

                    <div class="progress mb-3" style="height: 20px;">
                        <div class="progress-bar bg-success"
                             style="width:@item.ProgressPercent%">
                            @item.ProgressPercent%
                        </div>
                    </div>

                    <!-- Status -->
                    <p>
                        <strong>Status:</strong>
                        <span class="badge bg-info">@item.Status</span>
                    </p>

                    <!-- Eligible date -->
                    @if (item.Status == "Eligible")
                    {
                        <p><strong>Eligible Date:</strong> @item.EligibleDate</p>
                    }

                    <!-- Certificate -->
                    @if ((item.Status == "Eligible" || item.Status == "Certified") && cert != null)
                    {
                        <div class="alert alert-success mt-3">
                            🎓 <strong>Certificate Issued!</strong><br />

                            <div>Reference: <b>@cert.CertificateReferenceNumber</b></div>
                            <div>Issued Date: <b>@cert.IssuedDate</b></div>
                            <div>Status: <b>@cert.CertificateStatus</b></div>
                        </div>
                    }
                    else if (item.Status == "Eligible")
                    {
                        <div class="alert alert-warning mt-3">
                            Certificate is being generated...
                        </div>
                    }

                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No certification progress found.</p>
    }

</div>