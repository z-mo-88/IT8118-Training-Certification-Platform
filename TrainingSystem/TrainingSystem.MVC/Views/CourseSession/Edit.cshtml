@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Edit Session";
}

<div class="container py-5">
    <div class="card shadow-sm border-0" style="border-radius:18px;">
        <div class="card-body p-5">

            <h3 class="fw-bold mb-4" style="color:#0a1f5c;">Edit Session</h3>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SessionId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Course</label>
                        <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Instructor</label>
                        <select asp-for="UserId" asp-items="ViewBag.Instructors" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Room</label>
                        <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="form-select"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Date</label>
                        <input asp-for="SessionDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Start Time</label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">End Time</label>
                        <input asp-for="EndTime" type="time" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="fw-semibold">Capacity</label>
                        <input asp-for="SessionCapacity" class="form-control" />
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-light">Back</a>

                    <button type="submit" class="btn text-white"
                            style="background:#0a1f5c;">
                        Save Changes
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>