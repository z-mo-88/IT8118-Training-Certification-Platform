@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Edit Session";
}

<h2>Edit Course Session</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="SessionId" />

    <div class="form-group">
        <label>Course</label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Instructor</label>
        <select asp-for="UserId" asp-items="ViewBag.Instructors" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Room</label>
        <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Date</label>
        <input asp-for="SessionDate" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label>Start Time</label>
        <input asp-for="StartTime" type="time" class="form-control" />
    </div>

    <div class="form-group">
        <label>End Time</label>
        <input asp-for="EndTime" type="time" class="form-control" />
    </div>

    <div class="form-group">
        <label>Capacity</label>
        <input asp-for="SessionCapacity" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

<div asp-validation-summary="All" class="text-danger"></div>