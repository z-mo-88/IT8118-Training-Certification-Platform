@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Edit Session";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-9">

            <div class="card border-0 shadow-sm" style="border-radius:18px;">
                <div class="card-body p-4 p-lg-5">

                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color:#0a1f5c;">Edit Session</h3>
                        <p class="text-muted mb-0">Update the session details below.</p>
                    </div>

                    <form asp-action="Edit" method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="SessionId" />

                        <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4"></div>

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">Course</label>
                                <select asp-for="CourseId"
                                        asp-items="ViewBag.Courses"
                                        class="form-select"
                                        style="height:50px; border-radius:10px;">
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">Instructor</label>
                                <select asp-for="UserId"
                                        asp-items="ViewBag.Instructors"
                                        class="form-select"
                                        style="height:50px; border-radius:10px;">
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">Room</label>
                                <select asp-for="RoomId"
                                        asp-items="ViewBag.Rooms"
                                        class="form-select"
                                        style="height:50px; border-radius:10px;">
                                </select>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">Date</label>
                                <input asp-for="SessionDate"
                                       type="date"
                                       class="form-control"
                                       style="height:50px; border-radius:10px;" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">Start Time</label>
                                <input asp-for="StartTime"
                                       type="time"
                                       class="form-control"
                                       style="height:50px; border-radius:10px;" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold" style="color:#0a1f5c;">End Time</label>
                                <input asp-for="EndTime"
                                       type="time"
                                       class="form-control"
                                       style="height:50px; border-radius:10px;" />
                            </div>

                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" style="color:#0a1f5c;">Capacity</label>
                            <input asp-for="SessionCapacity"
                                   class="form-control"
                                   style="height:50px; border-radius:10px;" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn fw-semibold px-4"
                               style="border:1px solid #0a1f5c; color:#0a1f5c; border-radius:10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color:#0a1f5c; height:48px; border-radius:10px; border:none;">
                                Save Changes
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}