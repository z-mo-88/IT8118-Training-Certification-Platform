@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Create Session";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-9">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">

                <div class="card-body p-4 p-lg-5">
                    <div class="mb-4">
                        <h3 class="fw-bold mb-2" style="color: #0a1f5c;">Create Course Session</h3>
                        <p class="text-muted mb-0">Schedule a new session for a course.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-4"></div>
                    }

                    <form asp-action="Create" method="post">

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="CourseId" class="form-label fw-semibold" style="color: #0a1f5c;">Course</label>
                                <select asp-for="CourseId"
                                        asp-items="ViewBag.Courses"
                                        class="form-select"
                                        style="height: 50px; border-radius: 10px;">
                                    <option value="">-- Select Course --</option>
                                </select>
                                <span asp-validation-for="CourseId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="UserId" class="form-label fw-semibold" style="color: #0a1f5c;">Instructor</label>
                                <select asp-for="UserId"
                                        asp-items="ViewBag.Instructors"
                                        class="form-select"
                                        style="height: 50px; border-radius: 10px;">
                                    <option value="">-- Select Instructor --</option>
                                </select>
                                <span asp-validation-for="UserId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="RoomId" class="form-label fw-semibold" style="color: #0a1f5c;">Room</label>
                                <select asp-for="RoomId"
                                        asp-items="ViewBag.Rooms"
                                        class="form-select"
                                        style="height: 50px; border-radius: 10px;">
                                    <option value="">-- Select Room --</option>
                                </select>
                                <span asp-validation-for="RoomId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="SessionDate" class="form-label fw-semibold" style="color: #0a1f5c;">Date</label>
                                <input asp-for="SessionDate"
                                       type="date"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="SessionDate" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="StartTime" class="form-label fw-semibold" style="color: #0a1f5c;">Start Time</label>
                                <input asp-for="StartTime"
                                       type="time"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="StartTime" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="EndTime" class="form-label fw-semibold" style="color: #0a1f5c;">End Time</label>
                                <input asp-for="EndTime"
                                       type="time"
                                       class="form-control"
                                       style="height: 50px; border-radius: 10px;" />
                                <span asp-validation-for="EndTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SessionCapacity" class="form-label fw-semibold" style="color: #0a1f5c;">Capacity</label>
                            <input asp-for="SessionCapacity"
                                   type="number"
                                   min="1"
                                   class="form-control"
                                   placeholder="Enter session capacity"
                                   style="height: 50px; border-radius: 10px;" />
                            <span asp-validation-for="SessionCapacity" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold"
                               style="border-radius: 10px;">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn text-white fw-semibold px-4"
                                    style="background-color: #0a1f5c; height: 48px; border-radius: 10px; border: none;">
                                Create Session
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}