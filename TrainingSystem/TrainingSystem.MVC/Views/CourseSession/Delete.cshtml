@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Delete Session";
}

<h2>Delete Session</h2>

<h4>Are you sure?</h4>

<div>
    <p><strong>Course:</strong> @Model.Course?.Title</p>
    <p><strong>Date:</strong> @Model.SessionDate</p>
    <p><strong>Time:</strong> @Model.StartTime - @Model.EndTime</p>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="SessionId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>