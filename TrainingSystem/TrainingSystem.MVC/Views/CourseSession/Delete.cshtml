@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Delete Session";
}

<div class="container py-5">
    <div class="card shadow-sm border-0" style="border-radius:18px;">
        <div class="card-body p-5 text-center">

            <h3 class="text-danger fw-bold">Delete Session</h3>
            <p class="mt-3">Are you sure you want to delete this session?</p>

            <div class="mb-4">
                <strong>@Model.Course?.Title</strong><br />
                @Model.SessionDate
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SessionId" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-light">Cancel</a>

                    <button type="submit" class="btn btn-danger">
                        Delete
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>