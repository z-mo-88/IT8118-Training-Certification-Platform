@model TrainingSystem.API.Models.CourseSession

@{
    ViewData["Title"] = "Delete Session";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-6">
            <div class="card border-0 shadow-sm" style="border-radius: 18px;">

                <div class="card-body p-4 p-lg-5 text-center">

                    <h3 class="fw-bold mb-4" style="color: #0a1f5c;">Delete Session</h3>

                    <div class="mb-4">
                        <h5 class="fw-semibold mb-3" style="color: #0a1f5c;">
                            @Model.Course?.Title
                        </h5>

                        <div class="d-flex flex-column gap-2 text-muted">
                            <p class="mb-0">
                                <strong style="color: #0a1f5c;">Date:</strong> @Model.SessionDate
                            </p>
                            <p class="mb-0">
                                <strong style="color: #0a1f5c;">Time:</strong> @Model.StartTime - @Model.EndTime
                            </p>
                        </div>
                    </div>

                    <div class="alert alert-danger rounded-3 mb-4">
                        <strong>Are you sure?</strong><br />
                        This session will be permanently deleted.
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="SessionId" />

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a asp-action="Index"
                               class="btn btn-light fw-semibold px-4"
                               style="border-radius: 10px;">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn fw-semibold px-4 text-white"
                                    style="background-color: #dc3545; border-radius: 10px; border: none;">
                                Delete
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>