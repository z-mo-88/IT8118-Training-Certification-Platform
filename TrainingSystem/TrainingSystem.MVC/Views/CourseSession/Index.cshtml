@model IEnumerable<TrainingSystem.API.Models.CourseSession>

@{
    ViewData["Title"] = "Course Sessions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Course Sessions</h2>
    <a asp-action="Create" class="btn btn-primary">Create New Session</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Room</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Capacity</th>
                    <th>Available Seats</th>
                    <th>Status</th>
                    <th style="width: 160px;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Course?.Title</td>
                            <td>@item.User?.Name</td>
                            <td>@item.Room?.RoomName</td>
                            <td>@item.SessionDate.ToShortDateString()</td>
                            <td>@item.StartTime - @item.EndTime</td>
                            <td>@item.SessionCapacity</td>
                            <td id="seats-@item.SessionId">@item.AvailableSeats</td>
                            <td>@item.Status</td>
                            <td class="text-center">
                                <a asp-action="Delete" asp-route-id="@item.SessionId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted">No sessions found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("https://localhost:7258/enrollmentHub")
        .build();

    connection.on("EnrollmentUpdated", function (sessionId, seats) {
        const element = document.getElementById("seats-" + sessionId);
        if (element) {
            element.innerText = seats;
        }
    });

    connection.start().catch(err => console.error(err.toString()));
</script>