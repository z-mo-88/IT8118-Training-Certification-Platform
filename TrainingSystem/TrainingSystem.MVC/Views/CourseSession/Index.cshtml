@model IEnumerable<TrainingSystem.API.Models.CourseSession>

@{
    ViewData["Title"] = "Course Sessions";
}

<div class="container-fluid py-5 px-3 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color: #0a1f5c;">Course Sessions</h2>
            <p class="text-muted mb-0">Manage scheduled sessions, instructors, rooms, and seat availability.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create"
               class="btn text-white fw-semibold px-4"
               style="background-color: #0a1f5c; border-radius: 10px; border: none; height: 46px;">
                Create New Session
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 18px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead style="background-color: rgba(10, 31, 92, 0.06);">
                        <tr>
                            <th class="fw-semibold px-4 py-3" style="color: #0a1f5c;">Course</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Instructor</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Room</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Date</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Time</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Capacity</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Available Seats</th>
                            <th class="fw-semibold py-3" style="color: #0a1f5c;">Status</th>
                            <th class="fw-semibold py-3 text-center" style="color: #0a1f5c; width: 160px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold" style="color: #0a1f5c;">
                                        @item.Course?.Title
                                    </td>
                                    <td class="py-3">@item.User?.Name</td>
                                    <td class="py-3">@item.Room?.RoomName</td>
                                    <td class="py-3">@item.SessionDate.ToShortDateString()</td>
                                    <td class="py-3">@item.StartTime - @item.EndTime</td>
                                    <td class="py-3">@item.SessionCapacity</td>
                                    <td class="py-3">
                                        <span id="seats-@item.SessionId"
                                              class="fw-semibold"
                                              style="color: #0a1f5c;">
                                            @item.AvailableSeats
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background-color: rgba(10, 31, 92, 0.08); color: #0a1f5c; font-weight: 600;">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="text-center py-3">
                                        <a asp-action="Delete"
                                           asp-route-id="@item.SessionId"
                                           class="btn btn-sm fw-semibold px-3 text-white"
                                           style="background-color: #dc3545; border-radius: 10px; border: none;">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    No sessions found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("https://localhost:7258/enrollmentHub")
        .build();

    connection.on("EnrollmentUpdated", function (sessionId, availableSeats) {
        const element = document.getElementById("seats-" + sessionId);
        if (element) {
            element.innerText = availableSeats;
        }
    });

    connection.start().catch(err => console.error(err.toString()));
</script>