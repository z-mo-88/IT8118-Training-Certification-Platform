@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrainingSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">Training System</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- LEFT MENU -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Home/About">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Certificate/Lookup">Certificate Lookup</a>
                    </li>

                    <!-- ================= COORDINATOR ================= -->
                    @if (Context.Session.GetInt32("RoleId") == 3)
                    {
                        <li class="nav-item"><a class="nav-link text-white" href="/Courses">Courses</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/CourseSession">Sessions</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Users">Users</a></li>

                        <li class="nav-item"><a class="nav-link text-white" href="/Room">Rooms</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Equipment">Equipment</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/RoomEquipment">Room Equipment</a></li>

                        <li class="nav-item"><a class="nav-link text-white" href="/Payment">Payments</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Notification">Notifications</a></li>
                    }

                    <!-- ================= INSTRUCTOR ================= -->
                    @if (Context.Session.GetInt32("RoleId") == 2)
                    {
                        <li class="nav-item"><a class="nav-link text-white" href="/Sessions">My Sessions</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/SessionEnrollments">Students</a></li>

                        <li class="nav-item"><a class="nav-link text-white" href="/InstructorAvailability">My Availability</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/InstructorExpertise">My Expertise</a></li>
                    }

                    <!-- ================= TRAINEE ================= -->
                    @if (Context.Session.GetInt32("RoleId") == 1)
                    {
                        <li class="nav-item"><a class="nav-link text-white" href="/Enrollments">My Enrollments</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/MyCertificates">My Certificates</a></li>
                    }

                </ul>

                <!-- RIGHT MENU -->
                <ul class="navbar-nav">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-white">
                                Hello, @Context.Session.GetString("UserName")
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/Account/Logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/Account/Login">Login</a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>