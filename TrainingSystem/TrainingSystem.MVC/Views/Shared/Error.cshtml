@model TrainingSystem.MVC.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@if (Model != null && Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Development Mode</h3>

<p>
    Swapping to <strong>Development</strong> environment will display more detailed information about the error.
</p>

<p>
    <strong>Do not enable Development in production.</strong>
</p>